---
import type { PublicProperty } from '@/types/property';
import PropertyGallery from './PropertyGallery.tsx';
import PropertyMap from './PropertyMap.tsx';
import PropertyCard from './PropertyCard.astro';
import ContactForm from '@/components/forms/ContactForm.tsx';
import CompareBar from './CompareBar.tsx';
import { t, type Lang, localizedPath } from '@/lib/i18n';
import { formatRentalPrice, formatLocation } from '@/lib/format';
import { formatPublicRef } from '@/lib/reference';
import { getStatusBadge, getTransactionBadge } from '@/lib/status';
import { Bed, Maximize2, MapPin, Tag, Award, FileText, Download, Phone, MessageCircle } from 'lucide-react';

interface Props {
  property: PublicProperty;
  similar: PublicProperty[];
  lang: Lang;
}
const { property: p, similar, lang } = Astro.props;

const status = getStatusBadge(p.status);
const transaction = getTransactionBadge(p.transaction_type);

// Pretty-print the attributes JSONB — only keys we know about.
const ATTR_LABELS: Record<string, string> = {
  chambres: 'Chambres',
  salons: 'Salons',
  toilettes: 'Toilettes',
  cuisine: 'Cuisine',
  etage: 'Étage',
  parking: 'Parking',
  jardin: 'Jardin',
  piscine: 'Piscine',
  terrasse: 'Terrasse',
  balcon: 'Balcon',
  niveaux: 'Niveaux',
  ascenseur: 'Ascenseur',
  climatisation: 'Climatisation',
};
const attrEntries = Object.entries(p.attributes || {})
  .filter(([k, v]) => k in ATTR_LABELS && v !== false && v !== null && v !== '' && v !== 0)
  .map(([k, v]) => ({ label: ATTR_LABELS[k]!, value: typeof v === 'boolean' ? '✓' : String(v) }));

const documentEntries = Object.entries(p.documents || {})
  .filter(([, url]) => typeof url === 'string' && url.length > 0);

const priceLabel = formatRentalPrice(p.price, p.transaction_type);
---

<!-- ─────────────────────────────────────────────────────────────────────
     TOP SECTION: gallery + all property text in the left 2/3 column,
     sticky price/CTA card in the right 1/3. The price stays alongside
     the user while they scroll the gallery, description, specs etc.
     ───────────────────────────────────────────────────────────────────── -->
<section class="bg-card pt-6 sm:pt-10 pb-14 lg:pb-20">
  <div class="container">
    <a href={localizedPath('/biens', lang)} class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-primary mb-5">
      <span aria-hidden>←</span> Toutes les annonces
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_360px] gap-8 lg:gap-12">
      <!-- ─── LEFT 2/3: gallery + facts ───────────────────────────────── -->
      <div class="space-y-10">
        <!-- 1. Gallery (video left, photos right on desktop — see PropertyGallery) -->
        <PropertyGallery client:visible images={p.images} videoLinks={p.video_links} title={p.title} />

        <!-- 2. Header: badges, title, location, commercial pitch -->
        <div>
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class:list={['px-3 py-1.5 rounded-full text-[12px] font-semibold tracking-wide', transaction.badgeClass]}>
              {transaction.label}
            </span>
            <span class:list={['inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[12px] font-semibold tracking-wide uppercase', status.badgeClass]}>
              <span aria-hidden>{status.emoji}</span>{status.label}
            </span>
            {p.tags.map((tag) => (
              <span class="px-3 py-1.5 rounded-full text-[12px] font-semibold bg-ochre/10 text-ink border border-ochre/30">{tag}</span>
            ))}
            <span class="ml-auto text-[12px] font-mono text-muted-foreground/70">{formatPublicRef(p.reference)}</span>
          </div>

          <h1 class="font-serif font-light text-[clamp(28px,4vw,52px)] leading-tight tracking-tight [text-wrap:balance]">
            {p.title}
          </h1>

          <p class="mt-2 inline-flex items-center gap-2 text-muted-foreground">
            <MapPin className="w-4 h-4" />
            {formatLocation(p.city, p.quartier)}{p.address ? ` · ${p.address}` : ''}
          </p>

          {p.commercial_message && (
            <p class="mt-5 font-serif italic text-lg text-foreground/80 leading-relaxed max-w-[58ch]">
              « {p.commercial_message} »
            </p>
          )}

          <!-- Spec chips -->
          <div class="mt-7 flex flex-wrap gap-2.5">
            {p.bedrooms > 0 && (
              <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-background border border-clay text-sm">
                <Bed className="w-4 h-4 text-primary" />
                <span><b class="font-semibold">{p.bedrooms}</b> chambre{p.bedrooms > 1 ? 's' : ''}</span>
              </div>
            )}
            {p.surface > 0 && (
              <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-background border border-clay text-sm">
                <Maximize2 className="w-4 h-4 text-primary" />
                <span><b class="font-semibold">{p.surface}</b> m²</span>
              </div>
            )}
            {p.flux_passage && (p.type === 'Magasin' || p.type === 'Bureau' || p.type === 'Hangar') && (
              <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-background border border-clay text-sm">
                <Award className="w-4 h-4 text-secondary" />
                Flux passage {p.flux_passage}
              </div>
            )}
            <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-background border border-clay text-sm">
              <Tag className="w-4 h-4 text-primary" />
              {p.type}
            </div>
          </div>
        </div>

        <!-- 3. Description -->
        {p.description && (
          <div>
            <h2 class="font-serif text-2xl mb-4">{t('property.detail.description', lang)}</h2>
            <p class="text-foreground/80 leading-relaxed whitespace-pre-line max-w-[68ch]">{p.description}</p>
          </div>
        )}

        <!-- 4. Specs grid -->
        {attrEntries.length > 0 && (
          <div>
            <h2 class="font-serif text-2xl mb-4">{t('property.detail.specs', lang)}</h2>
            <dl class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {attrEntries.map((a) => (
                <div class="px-4 py-3 rounded-xl bg-background border border-clay">
                  <dt class="text-[11px] uppercase tracking-wider text-muted-foreground font-semibold">{a.label}</dt>
                  <dd class="text-[15px] mt-0.5">{a.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}

        <!-- 5. Commodities -->
        {p.commodities.length > 0 && (
          <div>
            <h2 class="font-serif text-2xl mb-4">{t('property.detail.commodities', lang)}</h2>
            <div class="flex flex-wrap gap-2">
              {p.commodities.map((c) => (
                <span class="px-3 py-1.5 rounded-full text-sm bg-accent text-accent-foreground border border-primary/15">{c}</span>
              ))}
            </div>
          </div>
        )}

        <!-- 6. Nearby commerce -->
        {p.nearby_commerce.length > 0 && (
          <div>
            <h2 class="font-serif text-2xl mb-4">{t('property.detail.nearby', lang)}</h2>
            <ul class="space-y-2">
              {p.nearby_commerce.map((n) => (
                <li class="flex justify-between items-center px-4 py-3 rounded-xl bg-background border border-clay">
                  <span class="text-sm">{n.name}</span>
                  <span class="text-[12px] font-semibold text-secondary">{n.distance}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- 7. Documents -->
        {documentEntries.length > 0 && (
          <div>
            <h2 class="font-serif text-2xl mb-4 flex items-center gap-2">
              <FileText className="w-5 h-5" />{t('property.detail.documents', lang)}
            </h2>
            <ul class="space-y-2">
              {documentEntries.map(([type, url]) => (
                <li>
                  <a href={url} download class="flex items-center justify-between p-4 rounded-xl bg-background border border-clay hover:border-primary transition">
                    <span class="text-sm capitalize">{type.replaceAll('_', ' ')}</span>
                    <Download className="w-4 h-4 text-primary" />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <!-- ─── RIGHT 1/3: sticky price + CTA ────────────────────────────── -->
      <aside class="hidden lg:block lg:sticky lg:top-24 self-start">
        <div class="rounded-3xl bg-gradient-to-b from-primary to-[hsl(var(--primary)/0.85)] text-primary-foreground p-7 shadow-xl">
          <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary-foreground/70">
            {transaction.label === 'À louer' ? 'Loyer mensuel' : 'Prix de vente'}
          </div>
          <div class="font-serif font-light text-[clamp(28px,3vw,40px)] leading-none tracking-tight mt-1.5">
            {priceLabel}
          </div>
          {p.negotiable && (
            <span class="inline-block mt-3 px-2.5 py-1 rounded-full text-[11px] font-semibold bg-secondary/30 text-secondary-foreground border border-secondary/50">
              {t('property.price.negotiable', lang)}
            </span>
          )}
          <p class="mt-4 text-xs text-primary-foreground/70">
            Conditions, caution, avance — sur demande.
          </p>
          <div class="mt-5 flex flex-col gap-2.5">
            <a href="#contact-bien" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-secondary text-secondary-foreground font-semibold shadow-md hover:translate-y-[-1px] transition">
              Je suis intéressé
            </a>
            <a href="tel:+221770000000" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-white/12 text-primary-foreground font-semibold border border-white/25 hover:bg-white/20 transition">
              <Phone className="w-4 h-4" /> Appeler l'agence
            </a>
            <a href="https://wa.me/221770000000" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-emerald/85 text-emerald-foreground font-semibold hover:bg-emerald transition">
              <MessageCircle className="w-4 h-4" /> WhatsApp
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────
     LOCATION — full-width map band.
     ───────────────────────────────────────────────────────────────────── -->
<section class="py-12 lg:py-16 bg-background border-y border-clay">
  <div class="container">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-6">
      <div>
        <div class="inline-flex items-center gap-2 text-[12px] font-semibold tracking-[0.14em] uppercase text-primary">
          <span class="w-6 h-px bg-primary" /> {t('property.detail.location', lang)}
        </div>
        <h2 class="font-serif text-2xl sm:text-3xl mt-2">{formatLocation(p.city, p.quartier)}</h2>
        {p.address && <p class="mt-1 text-sm text-muted-foreground">{p.address}</p>}
      </div>
    </div>
    <PropertyMap client:visible gps={p.gps} title={p.title} className="rounded-2xl overflow-hidden h-[360px] sm:h-[460px] border border-clay" />
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────
     CONTACT FORM
     ───────────────────────────────────────────────────────────────────── -->
<section id="contact-bien" class="py-16 lg:py-20 bg-card scroll-mt-24">
  <div class="container max-w-3xl">
    <h2 class="font-serif text-3xl text-center mb-2">{t('property.detail.contact', lang)}</h2>
    <p class="text-muted-foreground text-center mb-8">{t('property.detail.contactSub', lang)}</p>
    <ContactForm client:visible lang={lang} propertyId={p.id} propertyTitle={p.title} compact />
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────
     SIMILAR PROPERTIES
     ───────────────────────────────────────────────────────────────────── -->
{similar.length > 0 && (
  <section class="py-12 lg:py-16 bg-background border-t border-clay">
    <div class="container">
      <h2 class="font-serif text-2xl sm:text-3xl mb-8">{t('property.detail.similar', lang)}</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {similar.map((sp, i) => (
          <PropertyCard property={sp} lang={lang} delay={(['', 'd1', 'd2'] as const)[i % 3]} hideCompare />
        ))}
      </div>
    </div>
  </section>
)}

<!-- ─────────────────────────────────────────────────────────────────────
     MOBILE STICKY BOTTOM CTA BAR
     ───────────────────────────────────────────────────────────────────── -->
<div
  id="mobile-cta-bar"
  class="lg:hidden fixed bottom-0 inset-x-0 z-40 bg-background/96 backdrop-blur border-t border-clay px-4 py-3 pb-[max(0.75rem,env(safe-area-inset-bottom))] flex items-center gap-3 shadow-[0_-8px_24px_-12px_hsl(var(--ink)/.25)] transform translate-y-full transition-transform duration-300"
  data-cta-bar
>
  <div class="flex-1 min-w-0">
    <div class="text-[10px] uppercase tracking-wider text-muted-foreground font-semibold leading-none">
      {transaction.label === 'À louer' ? 'Loyer' : 'Prix'}
    </div>
    <div class="font-serif text-[18px] font-normal leading-tight tracking-tight truncate">
      {priceLabel}
    </div>
  </div>
  <a href="tel:+221770000000" aria-label="Appeler l'agence" class="w-11 h-11 grid place-items-center rounded-full bg-card border border-clay text-primary">
    <Phone className="w-4 h-4" />
  </a>
  <a href="https://wa.me/221770000000" aria-label="WhatsApp" class="w-11 h-11 grid place-items-center rounded-full bg-emerald/15 text-emerald border border-emerald/30">
    <MessageCircle className="w-4 h-4" />
  </a>
  <a href="#contact-bien" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full bg-secondary text-secondary-foreground font-semibold text-sm shadow-md whitespace-nowrap">
    Contacter
  </a>
</div>

<CompareBar client:idle lang={lang} />

<!-- View tracking beacon + mobile-CTA reveal -->
<script define:vars={{ propertyId: p.id }}>
  if ('requestIdleCallback' in window) {
    window.requestIdleCallback(() => {
      fetch('/api/views', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ property_id: propertyId, referrer: document.referrer || null }),
        keepalive: true,
      }).catch(() => {});
    });
  }

  const ctaBar = document.querySelector('[data-cta-bar]');
  if (ctaBar) {
    const onScroll = () => {
      const past = window.scrollY > 420;
      ctaBar.style.transform = past ? 'translateY(0)' : 'translateY(100%)';
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
