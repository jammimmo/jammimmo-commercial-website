---
import type { PublicProperty } from '@/types/property';
import VideoTour from './VideoTour.astro';
import PropertyGallery from './PropertyGallery.tsx';
import PropertyMap from './PropertyMap.tsx';
import PropertyCard from './PropertyCard.astro';
import ContactForm from '@/components/forms/ContactForm.tsx';
import CompareBar from './CompareBar.tsx';
import FavoriteToggle from './FavoriteToggle.tsx';
import BrandMark from '@/components/layout/BrandMark.astro';
import { t, type Lang, localizedPath } from '@/lib/i18n';
import { formatRentalPrice, formatLocation } from '@/lib/format';
import { formatPublicRef } from '@/lib/reference';
import { getStatusBadge, getTransactionBadge, statusLabel, transactionLabel, typeLabel } from '@/lib/status';
import { parseGps } from '@/lib/gps';
import { approximateLocation } from '@/lib/dakar-geo';
import { SITE, TEL_URI, MAILTO_URI } from '@/lib/site-config';
import listingTranslations from '@/data/listing-translations.json';
import {
  Bed, Maximize2, MapPin, Tag, FileText, Download,
  Phone, MessageCircle, Mail, Bath, Building2, Sparkles, ShieldCheck, Languages, Check, Camera,
} from 'lucide-react';

interface Props {
  property: PublicProperty;
  similar: PublicProperty[];
  lang: Lang;
}
const { property: p, similar, lang } = Astro.props;

const status = getStatusBadge(p.status);
const transaction = getTransactionBadge(p.transaction_type);
const isRental = p.transaction_type === 'Location';

const facts: Array<{ icon: 'bed' | 'surface' | 'type' | 'bath' | 'floor' | 'sparkles'; label: string; value: string }> = [];
if (p.bedrooms > 0) facts.push({ icon: 'bed', label: t('property.facts.bedrooms', lang), value: String(p.bedrooms) });
if (p.surface > 0) facts.push({ icon: 'surface', label: t('property.facts.surface', lang), value: `${p.surface} m²` });
facts.push({ icon: 'type', label: t('property.facts.type', lang), value: typeLabel(p.type, lang) });
const attrSdb = p.attributes?.toilettes ?? p.attributes?.salles_de_bain;
if (typeof attrSdb === 'number' && attrSdb > 0) {
  facts.push({ icon: 'bath', label: t('property.facts.bathrooms', lang), value: String(attrSdb) });
}
if (typeof p.attributes?.etage === 'string' && p.attributes.etage) {
  facts.push({ icon: 'floor', label: t('property.facts.floor', lang), value: p.attributes.etage });
} else if (typeof p.attributes?.niveaux === 'number' && p.attributes.niveaux > 0) {
  facts.push({ icon: 'floor', label: t('property.facts.levels', lang), value: String(p.attributes.niveaux) });
}
if (p.flux_passage && (p.type === 'Magasin' || p.type === 'Bureau' || p.type === 'Hangar')) {
  facts.push({ icon: 'sparkles', label: t('property.facts.footTraffic', lang), value: String(p.flux_passage) });
}

// Attributs SECONDAIRES uniquement : chambres/toilettes/salles_de_bain/etage/niveaux
// sont DÉJÀ dans la rangée `facts` ci-dessus → on ne les ré-émet jamais ici (sinon
// doublon « Chambres = 1 »). Cf. panel UX : une donnée = un seul endroit.
const ATTR_LABELS: Record<string, string> = {
  salons: 'Salons', cuisine: 'Cuisine', parking: 'Parking', jardin: 'Jardin', piscine: 'Piscine',
  terrasse: 'Terrasse', balcon: 'Balcon', ascenseur: 'Ascenseur', climatisation: 'Climatisation',
};
const FACTS_KEYS = new Set(['chambres', 'bedrooms', 'toilettes', 'salles_de_bain', 'etage', 'niveaux']);
const attrRaw = Object.entries(p.attributes || {})
  .filter(([k, v]) => k in ATTR_LABELS && !FACTS_KEYS.has(k) && v !== false && v !== null && v !== '' && v !== 0);
// Booléens → chips d'équipement (libellé seul, plus de « ✓ » comme valeur).
// Nombres/strings → cartes « Libellé : valeur » (valeur déjà formatée, on trim).
const amenityChips = attrRaw.filter(([, v]) => v === true).map(([k]) => ATTR_LABELS[k]!);
const countCards = attrRaw
  .filter(([, v]) => v !== true)
  .map(([k, v]) => ({ label: ATTR_LABELS[k]!, value: String(v).trim() }));
const hasCharacteristics = amenityChips.length > 0 || countCards.length > 0;
const hasEnviron = p.nearby_commerce.length > 0;

const documentEntries = Object.entries(p.documents || {})
  .filter(([, url]) => typeof url === 'string' && url.length > 0);

const priceLabel = formatRentalPrice(p.price, p.transaction_type);
const priceCaption = isRental
  ? t('property.detail.rentalPrice', lang)
  : t('property.detail.salePrice', lang);

const hasVideo = !!p.video_links?.length;
const hasImages = p.images.length > 0;
const hasMedia = hasVideo || hasImages;
const bothMedia = hasVideo && hasImages;

// Map: decide SERVER-SIDE whether a location is resolvable, so we never emit
// the dead "Localisation indisponible" placeholder. Same resolution logic as
// PropertyMap (exact GPS → approximate quartier/city centroid).
const hasMap = !!(parseGps(p.gps) || approximateLocation(p.quartier, p.city));

// ── Traduction des titres/descriptions ───────────────────────────────────
// Le contenu traduit est cuit AU BUILD : prioritairement depuis le champ
// `translations` du bien (à venir côté estate-flow / DB), sinon depuis le
// snapshot local `listing-translations.json`. On rend la VERSION TRADUITE par
// défaut sur les pages non-FR quand elle existe, l'original est gardé dans
// `data-tr-orig`, et un toggle (100 % client, AUCUN appel réseau) bascule
// entre les deux. Pas de traduction dispo → on affiche l'original, SANS badge
// ni bouton (donc plus jamais de « Traduit automatiquement » mensonger).
const trMap = (listingTranslations as Record<string, Record<string, Record<string, string>>>);
const trData = (p as any).translations?.[lang] ?? trMap[p.reference]?.[lang] ?? null;
const titleTr = lang !== 'fr' && trData?.title ? trData.title : null;
const msgTr = lang !== 'fr' && trData?.commercial_message ? trData.commercial_message : null;
const descTr = lang !== 'fr' && trData?.description ? trData.description : null;
const showTranslate = !!(titleTr || msgTr || descTr);
const trLabels = {
  badge: t('listing.translate.badge', lang),
  toOriginal: t('listing.translate.original', lang),
  toTranslated: t('listing.translate.seeTranslation', lang),
};
---

<div class="property-detail-bg pb-24 xl:pb-0">

  <!-- 1. TITLE BAND — flat header, no card, stays on bg-card -->
  <section class="bg-card pt-5 sm:pt-7 pb-3 sm:pb-5">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <a href={localizedPath('/biens', lang)} class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-primary mb-5">
          <span aria-hidden class="rtl-flip inline-block">←</span> {t('common.backToListings', lang)}
        </a>

        <div class="flex flex-wrap items-center gap-2 mb-4">
          <span class:list={['px-3 py-1.5 rounded-full text-[12px] font-semibold tracking-wide', transaction.badgeClass]}>
            {transactionLabel(p.transaction_type, lang)}
          </span>
          <span class:list={['inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[12px] font-semibold tracking-wide uppercase', status.badgeClass]}>
            <span aria-hidden>{status.emoji}</span>{statusLabel(p.status, lang)}
          </span>
          {p.tags.map((tag) => (
            <span class="px-3 py-1.5 rounded-full text-[12px] font-semibold bg-ochre/10 text-ink border border-ochre/30">{tag}</span>
          ))}
          {p.reference && (
            <button
              type="button"
              data-copy-ref
              data-ref={p.reference}
              data-copied={t('common.copied', lang)}
              class="ms-auto inline-flex items-center gap-1.5 text-[12px] font-mono text-muted-foreground hover:text-foreground transition"
              title={t('property.detail.copyRef', lang)}
              aria-label={t('property.detail.copyRef', lang)}
            >
              <span data-copy-ref-label class="bidi-ltr">{formatPublicRef(p.reference)}</span>
              <svg data-copy-ref-icon width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
              </svg>
            </button>
          )}
        </div>

        <h1
          class="font-serif font-light text-[clamp(28px,4vw,52px)] leading-tight tracking-tight [text-wrap:balance]"
          {...(titleTr ? { 'data-tr-field': 'title', 'data-tr-orig': p.title } : {})}
        >
          {titleTr ?? p.title}
        </h1>

        <p class="mt-2 inline-flex items-center gap-2 text-muted-foreground">
          <MapPin className="w-4 h-4" />
          {formatLocation(p.city, p.quartier)}{p.address ? ` · ${p.address}` : ''}
        </p>

        {/* Reassurance band (option 2) — slim verified-by-Jamm trust line. */}
        <a href="#trust-jamm" class="mt-4 inline-flex items-center gap-2 text-[13px] font-medium text-emerald hover:text-emerald/80 transition">
          <ShieldCheck className="w-4 h-4" />
          {t('safety.trust.band', lang)}
        </a>
      </div>
    </div>
  </section>

  <!-- 2. HERO ROW — media-first (left) + sticky rail (right) -->
  <section class="pt-5 lg:pt-7 pb-3 lg:pb-5">
    <div class="container">
      <div class="max-w-5xl mx-auto grid gap-4 lg:gap-5 xl:grid-cols-[minmax(0,1fr)_360px] items-start">

        <!-- MEDIA BLOCK — hauteur plancher CONSTANTE quel que soit le média (symétrie
             hero) ; galerie prioritaire, vidéo en colonne secondaire / centrée. -->
        <div class="rounded-2xl bg-card border border-clay p-3 sm:p-4 shadow-sm">
          <div class="h-[clamp(420px,46vw,560px)]">
            {hasMedia ? (
              bothMedia ? (
                <div class="h-full grid gap-3 lg:grid-cols-[minmax(0,1fr)_minmax(0,230px)] items-stretch">
                  <div class="h-full min-h-0">
                    <PropertyGallery client:visible images={p.images} title={p.title} />
                  </div>
                  <div class="h-full overflow-hidden rounded-2xl border border-clay bg-black ring-1 ring-ink/5">
                    <VideoTour videoLinks={p.video_links} title={p.title} />
                  </div>
                </div>
              ) : hasImages ? (
                <div class="h-full">
                  <PropertyGallery client:visible images={p.images} title={p.title} />
                </div>
              ) : (
                <div class="h-full grid place-items-center">
                  <div class="h-full aspect-[9/16] overflow-hidden rounded-2xl border border-clay bg-black ring-1 ring-ink/5">
                    <VideoTour videoLinks={p.video_links} title={p.title} />
                  </div>
                </div>
              )
            ) : (
              <div class="h-full rounded-2xl bg-accent border border-primary/10 grid place-items-center text-center px-6">
                <div>
                  <div class="mx-auto w-14 h-14 rounded-2xl bg-card border border-clay grid place-items-center shadow-sm">
                    <BrandMark size={36} />
                  </div>
                  <p class="font-serif text-xl mt-3 inline-flex items-center gap-2 justify-center">
                    <Camera className="w-5 h-5 text-primary" />{t('property.media.none.title', lang)}
                  </p>
                  <p class="text-muted-foreground text-sm mt-1.5 max-w-sm mx-auto">{t('property.media.none.body', lang)}</p>
                  <a href="#contact-bien" class="mt-4 inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full bg-secondary text-secondary-foreground font-semibold text-sm shadow-md hover:translate-y-[-1px] transition">
                    {t('property.media.none.cta', lang)} <span aria-hidden class="rtl-flip inline-block">→</span>
                  </a>
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- STICKY RAIL — price + contact + anti-scam -->
        <aside class="xl:sticky xl:top-24 self-start flex flex-col gap-3">
          <div class="rounded-2xl bg-gradient-to-br from-primary via-primary to-[hsl(var(--primary)/0.85)] text-primary-foreground shadow-xl overflow-hidden">
            <div class="p-5">
              <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary-foreground/70">
                {priceCaption}
              </div>
              <div class="flex flex-wrap items-baseline gap-3 mt-2">
                <div class="font-serif font-light text-[clamp(24px,2.6vw,36px)] leading-none tracking-tight bidi-ltr">
                  {priceLabel}
                </div>
                {p.negotiable && (
                  <span class="px-2.5 py-1 rounded-full text-[11px] font-semibold bg-secondary/30 text-secondary-foreground border border-secondary/50">
                    {t('property.price.negotiable', lang)}
                  </span>
                )}
              </div>
              <p class="mt-2.5 text-[12.5px] text-primary-foreground/70">
                {t('property.detail.priceTerms', lang)}
              </p>
            </div>

            <div class="h-px bg-white/15 mx-5" />

            <ul class="p-5 space-y-3 text-[14px]">
              <li class="flex items-start gap-3">
                <span class="w-9 h-9 rounded-full bg-white/12 grid place-items-center shrink-0">
                  <Phone className="w-4 h-4 text-secondary" />
                </span>
                <div>
                  <div class="text-[11px] uppercase tracking-wider text-primary-foreground/60 font-semibold">{t('property.detail.phone', lang)}</div>
                  <a href={TEL_URI} class="hover:text-secondary transition bidi-ltr">{SITE.phoneDisplay}</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-9 h-9 rounded-full bg-white/12 grid place-items-center shrink-0">
                  <Mail className="w-4 h-4 text-secondary" />
                </span>
                <div>
                  <div class="text-[11px] uppercase tracking-wider text-primary-foreground/60 font-semibold">{t('property.detail.email', lang)}</div>
                  <a href={MAILTO_URI} class="hover:text-secondary transition break-all bidi-ltr">{SITE.email}</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-9 h-9 rounded-full bg-white/12 grid place-items-center shrink-0">
                  <MapPin className="w-4 h-4 text-secondary" />
                </span>
                <div>
                  <div class="text-[11px] uppercase tracking-wider text-primary-foreground/60 font-semibold">{t('property.detail.agency', lang)}</div>
                  <span>Jamm Immobilier · Dakar</span>
                </div>
              </li>
            </ul>

            <div class="px-5 pb-5 flex flex-col gap-2.5">
              <a href="#contact-bien" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full bg-secondary text-secondary-foreground font-semibold shadow-md hover:translate-y-[-1px] transition">
                {t('property.detail.interested', lang)} <span aria-hidden class="rtl-flip inline-block">→</span>
              </a>
              <div class="grid grid-cols-2 gap-2.5">
                <a
                  href={TEL_URI}
                  data-track="phone.tapped"
                  data-track-prop-source="detail"
                  class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-full bg-white/12 text-primary-foreground font-semibold border border-white/25 hover:bg-white/20 transition"
                >
                  <Phone className="w-4 h-4" /> {t('property.detail.call', lang)}
                </a>
                <a
                  href={SITE.whatsappUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-track="whatsapp.tapped"
                  data-track-prop-source="detail"
                  class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-full bg-emerald/85 text-emerald-foreground font-semibold hover:bg-emerald transition"
                >
                  <MessageCircle className="w-4 h-4" /> {t('property.detail.whatsapp', lang)}
                </a>
              </div>
              <FavoriteToggle client:visible reference={p.reference} title={p.title} lang={lang} variant="pill" />
            </div>
          </div>

        </aside>
      </div>

      {/* Bande « Acheter en confiance » — pleine largeur sous le hero (sortie du
          rail pour rééquilibrer la hauteur média ↔ rail). CTA = lien secondaire. */}
      <div class="max-w-5xl mx-auto mt-3 lg:mt-4">
        <div id="trust-jamm" class="scroll-mt-24 rounded-2xl border border-emerald/25 bg-emerald/[0.06] px-5 sm:px-6 py-4 sm:py-5">
          <div class="flex flex-col lg:flex-row lg:items-center gap-4 lg:gap-6">
            <div class="shrink-0 lg:max-w-[230px]">
              <div class="inline-flex items-center gap-2 text-emerald">
                <ShieldCheck className="w-4.5 h-4.5" />
                <span class="text-[11px] uppercase tracking-[0.14em] font-semibold">{t('safety.trust.eyebrow', lang)}</span>
              </div>
              <p class="font-serif text-lg leading-snug mt-1 text-foreground">{t('safety.trust.title', lang)}</p>
            </div>
            <ul class="flex-1 grid sm:grid-cols-3 gap-2.5 lg:gap-5 text-sm text-foreground/80">
              {[t('safety.trust.point.deed', lang), t('safety.trust.point.seller', lang), t('safety.trust.point.nodouble', lang)].map((point) => (
                <li class="flex items-start gap-2">
                  <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full bg-emerald/15 text-emerald grid place-items-center">
                    <Check className="w-3.5 h-3.5" />
                  </span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
            <a
              href={localizedPath('/securite-fonciere', lang)}
              data-track="safety.fromDetail"
              class="shrink-0 inline-flex items-center gap-1.5 text-[13px] font-semibold text-emerald hover:text-emerald/80 transition"
            >
              <ShieldCheck className="w-4 h-4 shrink-0" />
              <span>{t('safety.detail.cta', lang)}</span>
              <span aria-hidden class="rtl-flip inline-block">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. DESCRIPTION — essentials (top) + description text (+ map if resolvable) -->
  <section class="py-3 lg:py-5">
    <div class="container">
      <article class="prop-description relative max-w-5xl mx-auto rounded-2xl bg-card border border-clay px-6 sm:px-9 py-7 sm:py-9 shadow-sm">
        <div class="prop-rule absolute top-8 bottom-8 w-1 rounded-r-full bg-gradient-to-b from-secondary via-secondary/60 to-transparent"></div>
        <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary flex items-center gap-2 flex-wrap">
          <span class="w-6 h-px bg-primary"></span>
          {t('property.detail.description', lang)}
          {showTranslate && (
            <span class="ms-auto inline-flex items-center gap-2.5 normal-case tracking-normal">
              <span data-tr-badge class="inline-flex items-center gap-1 text-[10px] font-medium text-muted-foreground">
                <Sparkles className="w-3 h-3" />{trLabels.badge}
              </span>
              <button
                type="button"
                data-tr-toggle
                class="inline-flex items-center gap-1 text-[11px] font-semibold text-primary hover:text-secondary underline underline-offset-2"
              >
                <Languages className="w-3.5 h-3.5" /><span data-tr-toggle-label>{trLabels.toOriginal}</span>
              </button>
            </span>
          )}
        </div>

        <!-- Essentials row — colourful icon cards -->
        {facts.length > 0 && (
          <div class="mt-6 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2.5">
            {facts.map((f, i) => (
              <div class:list={[
                'rounded-xl p-3 flex items-center gap-2.5 border transition',
                i % 3 === 0 && 'bg-accent border-primary/15',
                i % 3 === 1 && 'bg-secondary/10 border-secondary/25',
                i % 3 === 2 && 'bg-emerald/10 border-emerald/25',
              ]}>
                <div class:list={[
                  'w-9 h-9 rounded-lg grid place-items-center shrink-0',
                  i % 3 === 0 && 'bg-primary/10 text-primary',
                  i % 3 === 1 && 'bg-secondary/20 text-[hsl(20_60%_30%)]',
                  i % 3 === 2 && 'bg-emerald/20 text-emerald',
                ]}>
                  {f.icon === 'bed' && <Bed className="w-4 h-4" />}
                  {f.icon === 'surface' && <Maximize2 className="w-4 h-4" />}
                  {f.icon === 'type' && <Building2 className="w-4 h-4" />}
                  {f.icon === 'bath' && <Bath className="w-4 h-4" />}
                  {f.icon === 'floor' && <Tag className="w-4 h-4" />}
                  {f.icon === 'sparkles' && <Sparkles className="w-4 h-4" />}
                </div>
                <div class="min-w-0">
                  <div class="text-[10px] uppercase tracking-wider text-muted-foreground font-semibold leading-none">{f.label}</div>
                  <div class="text-[14px] font-semibold tracking-tight mt-1 truncate">{f.value}</div>
                </div>
              </div>
            ))}
          </div>
        )}

        <!-- description text LEFT, MAP RIGHT (only when resolvable; else full width) -->
        <div class:list={['mt-7 grid gap-5 lg:gap-6 items-stretch', hasMap ? 'lg:grid-cols-[minmax(0,1fr)_minmax(0,360px)]' : '']}>
          <div>
            {p.commercial_message && (
              <p class="font-serif italic text-[clamp(17px,1.3vw,21px)] text-foreground/85 leading-relaxed max-w-[58ch] mb-5">
                « <span {...(msgTr ? { 'data-tr-field': 'commercial_message', 'data-tr-orig': p.commercial_message } : {})}>{msgTr ?? p.commercial_message}</span> »
              </p>
            )}
            <div
              class="description-body text-foreground/85 leading-[1.75] text-[15.5px] whitespace-pre-line max-w-[68ch]"
              {...(descTr ? { 'data-tr-field': 'description', 'data-tr-orig': p.description } : {})}
            >{descTr ?? p.description}</div>
            {p.address && (
              <p class="mt-5 text-sm text-muted-foreground inline-flex items-center gap-2">
                <MapPin className="w-4 h-4" />{p.address}
              </p>
            )}
          </div>

          {hasMap && (
            <div class="rounded-xl overflow-hidden border border-clay min-h-[260px] lg:min-h-[320px]">
              <PropertyMap
                client:visible
                gps={p.gps}
                quartier={p.quartier}
                city={p.city}
                title={p.title}
                className="w-full h-full block"
              />
            </div>
          )}
        </div>
      </article>
    </div>
  </section>

  <!-- 4. INFORMATIONS DÉTAILLÉES -->
  {(hasCharacteristics || p.nearby_commerce.length > 0 || documentEntries.length > 0) && (
    <section class="py-3 lg:py-5">
      <div class="container">
        <div class="max-w-5xl mx-auto rounded-2xl bg-card border border-clay px-6 sm:px-9 py-7 sm:py-9 shadow-sm">
          <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary flex items-center gap-2">
            <span class="w-6 h-px bg-primary"></span>{t('property.detail.infoSectionLabel', lang)}
          </div>
          <h2 class="font-serif font-light text-[clamp(22px,2.4vw,32px)] tracking-tight mt-2 mb-6">
            {hasEnviron ? t('property.detail.infoSectionTitle', lang) : t('property.detail.features', lang)}
          </h2>

          {hasCharacteristics && (
            <div class="mb-7">
              {(hasEnviron || documentEntries.length > 0) && (
                <h3 class="font-serif text-lg tracking-tight mb-3">{t('property.detail.features', lang)}</h3>
              )}
              {countCards.length > 0 && (
                <dl class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
                  {countCards.map((a) => (
                    <div class="px-4 py-3 rounded-xl bg-background border border-clay">
                      <dt class="text-[11px] uppercase tracking-wider text-muted-foreground font-semibold">{a.label}</dt>
                      <dd class="text-[15px] mt-0.5">{a.value}</dd>
                    </div>
                  ))}
                </dl>
              )}
              {amenityChips.length > 0 && (
                <div class:list={['flex flex-wrap gap-2.5', countCards.length > 0 && 'mt-3']}>
                  {amenityChips.map((label) => (
                    <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-[13.5px] bg-accent text-accent-foreground border border-primary/15">
                      <Check className="w-3.5 h-3.5 text-primary shrink-0" />{label}
                    </span>
                  ))}
                </div>
              )}
            </div>
          )}

          {p.nearby_commerce.length > 0 && (
            <div class="mb-7">
              <h3 class="font-serif text-lg tracking-tight mb-3">{t('property.detail.nearby', lang)}</h3>
              <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
                {p.nearby_commerce.map((n) => (
                  <li class="flex justify-between items-center px-4 py-3 rounded-xl bg-background border border-clay">
                    <span class="text-sm">{n.name}</span>
                    <span class="text-[12px] font-semibold text-secondary-strong">{n.distance}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {documentEntries.length > 0 && (
            <div>
              <h3 class="font-serif text-lg tracking-tight mb-3 flex items-center gap-2">
                <FileText className="w-5 h-5" />{t('property.detail.documents', lang)}
              </h3>
              <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
                {documentEntries.map(([type, url]) => (
                  <li>
                    <a href={url} download class="flex items-center justify-between p-4 rounded-xl bg-background border border-clay hover:border-primary transition">
                      <span class="text-sm capitalize">{type.replaceAll('_', ' ')}</span>
                      <Download className="w-4 h-4 text-primary" />
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- 5. COMMODITÉS -->
  {p.commodities.length > 0 && (
    <section class="py-3 lg:py-5">
      <div class="container">
        <div class="max-w-5xl mx-auto rounded-2xl bg-card border border-clay px-6 sm:px-9 py-7 sm:py-9 shadow-sm">
          <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary flex items-center gap-2">
            <span class="w-6 h-px bg-primary"></span>{t('property.detail.commodities', lang)}
          </div>
          <h2 class="font-serif font-light text-[clamp(22px,2.4vw,32px)] tracking-tight mt-2 mb-6">
            {t('property.detail.amenities', lang)}
          </h2>
          <div class="flex flex-wrap gap-2.5">
            {p.commodities.map((c) => (
              <span class="px-4 py-2 rounded-full text-[14px] bg-accent text-accent-foreground border border-primary/15">{c}</span>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- 6. CONTACT FORM -->
  <section id="contact-bien" class="py-3 lg:py-6 scroll-mt-24">
    <div class="container">
      <div class="max-w-3xl mx-auto rounded-2xl bg-card border border-clay px-6 sm:px-10 py-8 sm:py-10 shadow-sm">
        <h2 class="font-serif text-2xl sm:text-3xl text-center mb-2">{t('property.detail.contact', lang)}</h2>
        <p class="text-muted-foreground text-center mb-7">{t('property.detail.contactSub', lang)}</p>
        <ContactForm client:visible lang={lang} propertyId={p.id} propertyTitle={p.title} compact />
      </div>
    </div>
  </section>

  <!-- 7. SIMILAR -->
  {similar.length > 0 && (
    <section class="py-3 lg:py-6">
      <div class="container">
        <div class="max-w-5xl mx-auto rounded-2xl bg-card border border-clay px-5 sm:px-8 py-7 sm:py-9 shadow-sm">
          <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary flex items-center gap-2">
            <span class="w-6 h-px bg-primary"></span>{t('property.detail.similarLabel', lang)}
          </div>
          <h2 class="font-serif font-light text-[clamp(22px,2.4vw,32px)] tracking-tight mt-2 mb-6">{t('property.detail.similar', lang)}</h2>
          <div class="grid gap-6 justify-center grid-cols-[repeat(auto-fit,minmax(280px,1fr))]">
            {similar.map((sp, i) => (
              <PropertyCard property={sp} lang={lang} delay={(['', 'd1', 'd2'] as const)[i % 3]} hideCompare />
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <div class="h-6 lg:h-10"></div>
</div>

<!-- Mobile sticky bottom CTA bar -->
<div
  id="mobile-cta-bar"
  class="xl:hidden fixed bottom-0 inset-x-0 z-40 bg-background/96 backdrop-blur border-t border-clay px-4 py-3 pb-[max(0.75rem,env(safe-area-inset-bottom))] flex items-center gap-3 shadow-[0_-8px_24px_-12px_hsl(var(--ink)/.25)] transform translate-y-full transition-transform duration-300"
  data-cta-bar
>
  <div class="flex-1 min-w-0">
    <div class="text-[10px] uppercase tracking-wider text-muted-foreground font-semibold leading-none">
      {isRental ? t('property.priceShort.rent', lang) : t('property.priceShort.sale', lang)}
    </div>
    <div class="font-serif text-[18px] font-normal leading-tight tracking-tight truncate bidi-ltr">
      {priceLabel}
    </div>
  </div>
  <a href={TEL_URI} data-track="phone.tapped" data-track-prop-source="sticky" aria-label={t('property.detail.call', lang)} class="w-11 h-11 grid place-items-center rounded-full bg-card border border-clay text-primary">
    <Phone className="w-4 h-4" />
  </a>
  <a href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer" data-track="whatsapp.tapped" data-track-prop-source="sticky" aria-label="WhatsApp" class="w-11 h-11 grid place-items-center rounded-full bg-emerald/15 text-emerald border border-emerald/30">
    <MessageCircle className="w-4 h-4" />
  </a>
  <a href="#contact-bien" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full bg-secondary text-secondary-foreground font-semibold text-sm shadow-md whitespace-nowrap">
    {t('property.cta.contact', lang)}
  </a>
</div>

<CompareBar client:idle lang={lang} />

<style>
  /* The description left accent rule — logical so it flips under RTL. */
  .prop-description .prop-rule { inset-inline-start: 0; }

  .prop-description .description-body::first-letter {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 300;
    font-size: 3.6em;
    line-height: 0.85;
    float: left;
    margin: 0.08em 0.14em 0 0;
    color: hsl(var(--primary));
  }
  /* RTL: the drop-cap floats to the right + mirrored margin. */
  [dir='rtl'] .prop-description .description-body::first-letter {
    float: right;
    margin: 0.08em 0 0 0.14em;
  }
</style>

<script define:vars={{ propertyId: p.id, trLabels }}>
  if ('requestIdleCallback' in window) {
    window.requestIdleCallback(() => {
      fetch('/api/views', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ property_id: propertyId, referrer: document.referrer || null }),
        keepalive: true,
      }).catch(() => {});
    });
  }

  const ctaBar = document.querySelector('[data-cta-bar]');
  if (ctaBar) {
    const onScroll = () => {
      const past = window.scrollY > 420;
      ctaBar.style.transform = past ? 'translateY(0)' : 'translateY(100%)';
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Référence copiable : clic → copie la réf complète + feedback « ✓ Copié ».
  var copyBtn = document.querySelector('[data-copy-ref]');
  if (copyBtn) {
    copyBtn.addEventListener('click', function () {
      var ref = copyBtn.getAttribute('data-ref') || '';
      var label = copyBtn.querySelector('[data-copy-ref-label]');
      var done = function () {
        if (!label) return;
        var prev = label.textContent;
        label.textContent = '✓ ' + (copyBtn.getAttribute('data-copied') || 'Copié');
        setTimeout(function () { label.textContent = prev; }, 1600);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(ref).then(done).catch(done);
      } else {
        done();
      }
    });
  }

  // --- Traduction : toggle 100 % client sur du contenu DÉJÀ cuit au build. ---
  // La version traduite est rendue par défaut ; on bascule vers l'original
  // (stocké dans data-tr-orig) et retour. AUCUN appel réseau. Le badge est
  // masqué via style.display (PAS l'attribut `hidden`, qui était écrasé par la
  // classe utilitaire inline-flex et affichait un faux « Traduit auto. »).
  (function () {
    var toggle = document.querySelector('[data-tr-toggle]');
    if (!toggle) return;
    var fields = Array.prototype.slice.call(document.querySelectorAll('[data-tr-field][data-tr-orig]'));
    if (!fields.length) { toggle.style.display = 'none'; return; }
    fields.forEach(function (el) { el.setAttribute('data-tr-translated', el.textContent); });
    var badge = document.querySelector('[data-tr-badge]');
    var tlabel = toggle.querySelector('[data-tr-toggle-label]');
    var state = 'tr'; // traduit par défaut
    function apply() {
      fields.forEach(function (el) {
        el.textContent = state === 'tr'
          ? el.getAttribute('data-tr-translated')
          : el.getAttribute('data-tr-orig');
      });
      if (badge) badge.style.display = state === 'tr' ? '' : 'none';
      if (tlabel) tlabel.textContent = state === 'tr' ? trLabels.toOriginal : trLabels.toTranslated;
    }
    toggle.addEventListener('click', function () { state = state === 'tr' ? 'orig' : 'tr'; apply(); });
    apply();
  })();
</script>
