---
import type { PublicProperty } from '@/types/property';
import PropertyGallery from './PropertyGallery.tsx';
import PropertyMap from './PropertyMap.tsx';
import PropertyCard from './PropertyCard.astro';
import ContactForm from '@/components/forms/ContactForm.tsx';
import CompareBar from './CompareBar.tsx';
import { t, type Lang, localizedPath } from '@/lib/i18n';
import { formatRentalPrice, formatLocation } from '@/lib/format';
import { formatPublicRef } from '@/lib/reference';
import { getStatusBadge, getTransactionBadge } from '@/lib/status';
import {
  Bed, Maximize2, MapPin, Tag, Award, FileText, Download,
  Phone, MessageCircle, Mail, Bath, Building2, Sparkles,
} from 'lucide-react';

interface Props {
  property: PublicProperty;
  similar: PublicProperty[];
  lang: Lang;
}
const { property: p, similar, lang } = Astro.props;

const status = getStatusBadge(p.status);
const transaction = getTransactionBadge(p.transaction_type);

// Quick-fact icon cards — colourful palette
const facts: Array<{ icon: 'bed' | 'surface' | 'type' | 'bath' | 'floor' | 'sparkles'; label: string; value: string }> = [];
if (p.bedrooms > 0) facts.push({ icon: 'bed', label: 'Chambres', value: String(p.bedrooms) });
if (p.surface > 0) facts.push({ icon: 'surface', label: 'Surface', value: `${p.surface} m²` });
facts.push({ icon: 'type', label: 'Type', value: p.type });
const attrSdb = p.attributes?.toilettes ?? p.attributes?.salles_de_bain;
if (typeof attrSdb === 'number' && attrSdb > 0) {
  facts.push({ icon: 'bath', label: 'Salles d\'eau', value: String(attrSdb) });
}
if (typeof p.attributes?.etage === 'string' && p.attributes.etage) {
  facts.push({ icon: 'floor', label: 'Étage', value: p.attributes.etage });
} else if (typeof p.attributes?.niveaux === 'number' && p.attributes.niveaux > 0) {
  facts.push({ icon: 'floor', label: 'Niveaux', value: String(p.attributes.niveaux) });
}
if (p.flux_passage && (p.type === 'Magasin' || p.type === 'Bureau' || p.type === 'Hangar')) {
  facts.push({ icon: 'sparkles', label: 'Flux passage', value: String(p.flux_passage) });
}

const ATTR_LABELS: Record<string, string> = {
  chambres: 'Chambres', salons: 'Salons', toilettes: 'Toilettes', cuisine: 'Cuisine',
  etage: 'Étage', parking: 'Parking', jardin: 'Jardin', piscine: 'Piscine',
  terrasse: 'Terrasse', balcon: 'Balcon', niveaux: 'Niveaux',
  ascenseur: 'Ascenseur', climatisation: 'Climatisation',
};
const attrEntries = Object.entries(p.attributes || {})
  .filter(([k, v]) => k in ATTR_LABELS && v !== false && v !== null && v !== '' && v !== 0)
  .map(([k, v]) => ({ label: ATTR_LABELS[k]!, value: typeof v === 'boolean' ? '✓' : String(v) }));

const documentEntries = Object.entries(p.documents || {})
  .filter(([, url]) => typeof url === 'string' && url.length > 0);

const priceLabel = formatRentalPrice(p.price, p.transaction_type);
const priceCaption = transaction.label === 'À louer' ? 'Loyer mensuel' : 'Prix de vente';
---

<!-- ─────────────────────────────────────────────────────────────────────
     1. TITLE BAND — breadcrumb · badges · title · location
     ───────────────────────────────────────────────────────────────────── -->
<section class="bg-card pt-6 sm:pt-10 pb-5 sm:pb-7">
  <div class="container">
    <a href={localizedPath('/biens', lang)} class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-primary mb-5">
      <span aria-hidden>←</span> Toutes les annonces
    </a>

    <div class="flex flex-wrap items-center gap-2 mb-4">
      <span class:list={['px-3 py-1.5 rounded-full text-[12px] font-semibold tracking-wide', transaction.badgeClass]}>
        {transaction.label}
      </span>
      <span class:list={['inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[12px] font-semibold tracking-wide uppercase', status.badgeClass]}>
        <span aria-hidden>{status.emoji}</span>{status.label}
      </span>
      {p.tags.map((tag) => (
        <span class="px-3 py-1.5 rounded-full text-[12px] font-semibold bg-ochre/10 text-ink border border-ochre/30">{tag}</span>
      ))}
      <span class="ml-auto text-[12px] font-mono text-muted-foreground/70">{formatPublicRef(p.reference)}</span>
    </div>

    <h1 class="font-serif font-light text-[clamp(28px,4vw,52px)] leading-tight tracking-tight [text-wrap:balance]">
      {p.title}
    </h1>

    <p class="mt-2 inline-flex items-center gap-2 text-muted-foreground">
      <MapPin className="w-4 h-4" />
      {formatLocation(p.city, p.quartier)}{p.address ? ` · ${p.address}` : ''}
    </p>
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────
     2. HERO GALLERY — full-container 16:9 with thumb strip (Zillow-style)
     ───────────────────────────────────────────────────────────────────── -->
<section class="bg-card pb-8 lg:pb-12">
  <div class="container">
    <PropertyGallery client:visible images={p.images} videoLinks={p.video_links} title={p.title} />
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────
     3. BODY — 2-col grid:  details LEFT, sticky price + contact RIGHT
     ───────────────────────────────────────────────────────────────────── -->
<section class="py-10 lg:py-14 bg-background">
  <div class="container">
    <div class="grid gap-8 lg:gap-12 lg:grid-cols-[minmax(0,1fr)_360px]">
      <!-- LEFT: long-form content -->
      <div class="space-y-10">
        <!-- 3a. Colourful quick-facts band -->
        {facts.length > 0 && (
          <div>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {facts.map((f, i) => (
                <div class:list={[
                  'rounded-2xl p-4 flex items-center gap-3 border transition',
                  i % 3 === 0 && 'bg-accent border-primary/15',
                  i % 3 === 1 && 'bg-secondary/10 border-secondary/25',
                  i % 3 === 2 && 'bg-emerald/10 border-emerald/25',
                ]}>
                  <div class:list={[
                    'w-10 h-10 rounded-xl grid place-items-center shrink-0',
                    i % 3 === 0 && 'bg-primary/10 text-primary',
                    i % 3 === 1 && 'bg-secondary/20 text-[hsl(20_60%_30%)]',
                    i % 3 === 2 && 'bg-emerald/20 text-emerald',
                  ]}>
                    {f.icon === 'bed' && <Bed className="w-5 h-5" />}
                    {f.icon === 'surface' && <Maximize2 className="w-5 h-5" />}
                    {f.icon === 'type' && <Building2 className="w-5 h-5" />}
                    {f.icon === 'bath' && <Bath className="w-5 h-5" />}
                    {f.icon === 'floor' && <Tag className="w-5 h-5" />}
                    {f.icon === 'sparkles' && <Sparkles className="w-5 h-5" />}
                  </div>
                  <div class="min-w-0">
                    <div class="text-[11px] uppercase tracking-wider text-muted-foreground font-semibold leading-none">{f.label}</div>
                    <div class="text-[16px] font-semibold tracking-tight mt-1 truncate">{f.value}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- 3b. Description — magazine card -->
        {p.description && (
          <article class="prop-description relative rounded-2xl bg-card border border-clay px-6 sm:px-8 py-7 sm:py-9 shadow-sm">
            <div class="absolute left-0 top-6 bottom-6 w-1 rounded-r-full bg-gradient-to-b from-secondary via-secondary/60 to-transparent"></div>
            <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary flex items-center gap-2">
              <span class="w-6 h-px bg-primary"></span>
              {t('property.detail.description', lang)}
            </div>
            <h2 class="font-serif font-light text-[clamp(22px,2.4vw,32px)] tracking-tight mt-2">
              Le bien en quelques mots
            </h2>
            {p.commercial_message && (
              <p class="mt-5 font-serif italic text-[clamp(17px,1.3vw,21px)] text-foreground/85 leading-relaxed max-w-[58ch]">
                « {p.commercial_message} »
              </p>
            )}
            <div class="mt-6 description-body text-foreground/85 leading-[1.75] text-[16px] whitespace-pre-line max-w-[68ch]">{p.description}</div>
          </article>
        )}

        <!-- 3c. Specs grid -->
        {attrEntries.length > 0 && (
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary flex items-center gap-2 mb-2">
              <span class="w-6 h-px bg-primary"></span>{t('property.detail.specs', lang)}
            </div>
            <h2 class="font-serif font-light text-[clamp(22px,2.4vw,32px)] tracking-tight mb-5">Caractéristiques</h2>
            <dl class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {attrEntries.map((a) => (
                <div class="px-4 py-3 rounded-xl bg-card border border-clay">
                  <dt class="text-[11px] uppercase tracking-wider text-muted-foreground font-semibold">{a.label}</dt>
                  <dd class="text-[15px] mt-0.5">{a.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}

        <!-- 3d. Commodities -->
        {p.commodities.length > 0 && (
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary flex items-center gap-2 mb-2">
              <span class="w-6 h-px bg-primary"></span>{t('property.detail.commodities', lang)}
            </div>
            <h2 class="font-serif font-light text-[clamp(22px,2.4vw,32px)] tracking-tight mb-5">Équipements et services</h2>
            <div class="flex flex-wrap gap-2">
              {p.commodities.map((c) => (
                <span class="px-3 py-1.5 rounded-full text-sm bg-accent text-accent-foreground border border-primary/15">{c}</span>
              ))}
            </div>
          </div>
        )}

        <!-- 3e. Nearby -->
        {p.nearby_commerce.length > 0 && (
          <div>
            <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary flex items-center gap-2 mb-2">
              <span class="w-6 h-px bg-primary"></span>{t('property.detail.nearby', lang)}
            </div>
            <h2 class="font-serif font-light text-[clamp(22px,2.4vw,32px)] tracking-tight mb-5">À proximité</h2>
            <ul class="space-y-2">
              {p.nearby_commerce.map((n) => (
                <li class="flex justify-between items-center px-4 py-3 rounded-xl bg-card border border-clay">
                  <span class="text-sm">{n.name}</span>
                  <span class="text-[12px] font-semibold text-secondary">{n.distance}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- 3f. Documents -->
        {documentEntries.length > 0 && (
          <div>
            <h2 class="font-serif text-2xl mb-4 flex items-center gap-2">
              <FileText className="w-5 h-5" />{t('property.detail.documents', lang)}
            </h2>
            <ul class="space-y-2">
              {documentEntries.map(([type, url]) => (
                <li>
                  <a href={url} download class="flex items-center justify-between p-4 rounded-xl bg-card border border-clay hover:border-primary transition">
                    <span class="text-sm capitalize">{type.replaceAll('_', ' ')}</span>
                    <Download className="w-4 h-4 text-primary" />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <!-- RIGHT: sticky price + contact card -->
      <aside class="hidden lg:block lg:sticky lg:top-24 self-start">
        <div class="rounded-3xl bg-gradient-to-br from-primary via-primary to-[hsl(var(--primary)/0.85)] text-primary-foreground shadow-xl overflow-hidden">
          <!-- Price -->
          <div class="p-6">
            <div class="text-[11px] uppercase tracking-[0.14em] font-semibold text-primary-foreground/70">
              {priceCaption}
            </div>
            <div class="flex flex-wrap items-baseline gap-3 mt-2">
              <div class="font-serif font-light text-[clamp(28px,3vw,40px)] leading-none tracking-tight">
                {priceLabel}
              </div>
              {p.negotiable && (
                <span class="px-2.5 py-1 rounded-full text-[11px] font-semibold bg-secondary/30 text-secondary-foreground border border-secondary/50">
                  {t('property.price.negotiable', lang)}
                </span>
              )}
            </div>
            <p class="mt-3 text-[12.5px] text-primary-foreground/70">
              Conditions, caution, avance — sur demande.
            </p>
          </div>

          <div class="h-px bg-white/15 mx-6" />

          <!-- Contact -->
          <ul class="p-6 space-y-3 text-[14px]">
            <li class="flex items-start gap-3">
              <span class="w-9 h-9 rounded-full bg-white/12 grid place-items-center shrink-0">
                <Phone className="w-4 h-4 text-secondary" />
              </span>
              <div>
                <div class="text-[11px] uppercase tracking-wider text-primary-foreground/60 font-semibold">Téléphone</div>
                <a href="tel:+221770000000" class="hover:text-secondary transition">+221 77 000 00 00</a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-9 h-9 rounded-full bg-white/12 grid place-items-center shrink-0">
                <Mail className="w-4 h-4 text-secondary" />
              </span>
              <div>
                <div class="text-[11px] uppercase tracking-wider text-primary-foreground/60 font-semibold">E-mail</div>
                <a href="mailto:contact@jammimmo.com" class="hover:text-secondary transition break-all">contact@jammimmo.com</a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-9 h-9 rounded-full bg-white/12 grid place-items-center shrink-0">
                <MapPin className="w-4 h-4 text-secondary" />
              </span>
              <div>
                <div class="text-[11px] uppercase tracking-wider text-primary-foreground/60 font-semibold">Agence</div>
                <span>Jamm Immobilier · Dakar</span>
              </div>
            </li>
          </ul>

          <!-- CTAs -->
          <div class="px-6 pb-6 flex flex-col gap-2.5">
            <a href="#contact-bien" class="inline-flex items-center justify-center gap-2 px-5 py-3.5 rounded-full bg-secondary text-secondary-foreground font-semibold shadow-md hover:translate-y-[-1px] transition">
              Je suis intéressé →
            </a>
            <div class="grid grid-cols-2 gap-2.5">
              <a href="tel:+221770000000" class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-full bg-white/12 text-primary-foreground font-semibold border border-white/25 hover:bg-white/20 transition">
                <Phone className="w-4 h-4" /> Appeler
              </a>
              <a href="https://wa.me/221770000000" class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-full bg-emerald/85 text-emerald-foreground font-semibold hover:bg-emerald transition">
                <MessageCircle className="w-4 h-4" /> WhatsApp
              </a>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────
     4. LOCATION — full-width map band
     ───────────────────────────────────────────────────────────────────── -->
<section class="py-12 lg:py-16 bg-card border-y border-clay">
  <div class="container">
    <div class="mb-6">
      <div class="inline-flex items-center gap-2 text-[12px] font-semibold tracking-[0.14em] uppercase text-primary">
        <span class="w-6 h-px bg-primary" /> {t('property.detail.location', lang)}
      </div>
      <h2 class="font-serif text-2xl sm:text-3xl mt-2">{formatLocation(p.city, p.quartier)}</h2>
      {p.address && <p class="mt-1 text-sm text-muted-foreground">{p.address}</p>}
    </div>
    <PropertyMap client:visible gps={p.gps} title={p.title} className="rounded-2xl overflow-hidden h-[360px] sm:h-[460px] border border-clay" />
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────
     5. CONTACT FORM
     ───────────────────────────────────────────────────────────────────── -->
<section id="contact-bien" class="py-16 lg:py-20 bg-background scroll-mt-24">
  <div class="container max-w-3xl">
    <h2 class="font-serif text-3xl text-center mb-2">{t('property.detail.contact', lang)}</h2>
    <p class="text-muted-foreground text-center mb-8">{t('property.detail.contactSub', lang)}</p>
    <ContactForm client:visible lang={lang} propertyId={p.id} propertyTitle={p.title} compact />
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────
     6. SIMILAR
     ───────────────────────────────────────────────────────────────────── -->
{similar.length > 0 && (
  <section class="py-12 lg:py-16 bg-card border-t border-clay">
    <div class="container">
      <h2 class="font-serif text-2xl sm:text-3xl mb-8">{t('property.detail.similar', lang)}</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {similar.map((sp, i) => (
          <PropertyCard property={sp} lang={lang} delay={(['', 'd1', 'd2'] as const)[i % 3]} hideCompare />
        ))}
      </div>
    </div>
  </section>
)}

<!-- ─────────────────────────────────────────────────────────────────────
     MOBILE STICKY BOTTOM CTA BAR
     ───────────────────────────────────────────────────────────────────── -->
<div
  id="mobile-cta-bar"
  class="lg:hidden fixed bottom-0 inset-x-0 z-40 bg-background/96 backdrop-blur border-t border-clay px-4 py-3 pb-[max(0.75rem,env(safe-area-inset-bottom))] flex items-center gap-3 shadow-[0_-8px_24px_-12px_hsl(var(--ink)/.25)] transform translate-y-full transition-transform duration-300"
  data-cta-bar
>
  <div class="flex-1 min-w-0">
    <div class="text-[10px] uppercase tracking-wider text-muted-foreground font-semibold leading-none">
      {transaction.label === 'À louer' ? 'Loyer' : 'Prix'}
    </div>
    <div class="font-serif text-[18px] font-normal leading-tight tracking-tight truncate">
      {priceLabel}
    </div>
  </div>
  <a href="tel:+221770000000" aria-label="Appeler l'agence" class="w-11 h-11 grid place-items-center rounded-full bg-card border border-clay text-primary">
    <Phone className="w-4 h-4" />
  </a>
  <a href="https://wa.me/221770000000" aria-label="WhatsApp" class="w-11 h-11 grid place-items-center rounded-full bg-emerald/15 text-emerald border border-emerald/30">
    <MessageCircle className="w-4 h-4" />
  </a>
  <a href="#contact-bien" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full bg-secondary text-secondary-foreground font-semibold text-sm shadow-md whitespace-nowrap">
    Contacter
  </a>
</div>

<CompareBar client:idle lang={lang} />

<style>
  .prop-description .description-body::first-letter {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 300;
    font-size: 3.6em;
    line-height: 0.85;
    float: left;
    margin: 0.08em 0.14em 0 0;
    color: hsl(var(--primary));
  }
</style>

<script define:vars={{ propertyId: p.id }}>
  if ('requestIdleCallback' in window) {
    window.requestIdleCallback(() => {
      fetch('/api/views', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ property_id: propertyId, referrer: document.referrer || null }),
        keepalive: true,
      }).catch(() => {});
    });
  }

  const ctaBar = document.querySelector('[data-cta-bar]');
  if (ctaBar) {
    const onScroll = () => {
      const past = window.scrollY > 420;
      ctaBar.style.transform = past ? 'translateY(0)' : 'translateY(100%)';
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
