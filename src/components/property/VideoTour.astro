---
import { youtubeIdFromUrl } from '@/lib/youtube';

interface Props {
  videoLinks: string[];
  title: string;
}

const { videoLinks, title } = Astro.props;

const first = videoLinks
  .map((url) => youtubeIdFromUrl(url))
  .find((id): id is string => id !== null);

// Click-to-play poster instead of an eager iframe: a dead/private YouTube video
// no longer paints a full-frame black "Video unavailable" embed on load (it only
// shows if the user actually clicks). The poster falls back hqdefault → mqdefault.
const poster = first ? `https://img.youtube.com/vi/${first}/hqdefault.jpg` : null;
const embed = first
  ? `https://www.youtube-nocookie.com/embed/${first}?rel=0&modestbranding=1&autoplay=1`
  : null;
---

{first && (
  <div class="jamm-video relative w-full h-full bg-black" data-embed={embed}>
    <button
      type="button"
      class="jamm-video-poster group absolute inset-0 w-full h-full block"
      aria-label={`Lire la vidéo — ${title}`}
    >
      <img
        src={poster}
        alt=""
        loading="lazy"
        class="w-full h-full object-cover opacity-90"
        onerror="this.onerror=null;this.src=this.src.replace('hqdefault','mqdefault')"
      />
      <span class="absolute inset-0 grid place-items-center bg-black/25 group-hover:bg-black/15 transition-colors">
        <span class="w-16 h-16 rounded-full bg-white/95 grid place-items-center shadow-lg group-hover:scale-105 transition-transform">
          <svg width="20" height="24" viewBox="0 0 22 26" fill="none" aria-hidden="true">
            <path d="M21 11.27a2 2 0 0 1 0 3.46L3 25.2A2 2 0 0 1 0 23.46V2.54A2 2 0 0 1 3 .8l18 10.47Z" fill="hsl(234 60% 36%)" />
          </svg>
        </span>
      </span>
    </button>
  </div>
)}

<script>
  document.querySelectorAll('.jamm-video').forEach((box) => {
    box.querySelector('.jamm-video-poster')?.addEventListener('click', () => {
      const src = box.getAttribute('data-embed');
      if (!src) return;
      const f = document.createElement('iframe');
      f.src = src;
      f.title = box.getAttribute('aria-label') || 'Vidéo';
      f.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      f.allowFullscreen = true;
      f.loading = 'lazy';
      f.referrerPolicy = 'strict-origin-when-cross-origin';
      f.className = 'w-full h-full block';
      box.replaceChildren(f);
    });
  });
</script>
