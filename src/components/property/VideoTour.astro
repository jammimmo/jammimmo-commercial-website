---
import { youtubeIdFromUrl, youtubeAspect } from '@/lib/youtube';

interface Props {
  videoLinks: string[];
  title: string;
}

const { videoLinks, title } = Astro.props;

const videos = videoLinks
  .map((url) => ({ url, id: youtubeIdFromUrl(url) }))
  .filter((v): v is { url: string; id: string } => v.id !== null);
---

{videos.length > 0 && (
  <div id="visite-video" class="scroll-mt-24">
    <div class="flex flex-col gap-3 w-full max-w-[300px] mx-auto xl:mx-0">
      {videos.map((v) => (
        <div
          class="overflow-hidden rounded-2xl border border-clay bg-black w-full shadow-sm ring-1 ring-ink/5"
          style={`aspect-ratio: ${youtubeAspect(v.url)}`}
        >
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${v.id}?rel=0&modestbranding=1`}
            title={`Vidéo — ${title}`}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            class="w-full h-full"
          ></iframe>
        </div>
      ))}
      <p class="text-[12px] uppercase tracking-[0.14em] font-semibold text-muted-foreground flex items-center gap-1.5 mt-1 xl:justify-start justify-center">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        Visite vidéo
      </p>
    </div>
  </div>
)}
