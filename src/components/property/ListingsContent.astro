---
import { listPublicProperties } from '@/lib/supabase.build';
import ListingsView from './ListingsView.tsx';
import CompareBar from './CompareBar.tsx';
import { t, getLang, localizedPath } from '@/lib/i18n';

const lang = getLang(Astro.url);
const properties = await listPublicProperties({ limit: 200 });
const cities = [...new Set(properties.map((p) => p.city).filter(Boolean))].sort();

// Build a ref → /biens/<ref> map server-side so the React island doesn't
// need to know about i18n routing.
const hrefByRef = Object.fromEntries(
  properties.map((p) => [p.reference, localizedPath(`/biens/${p.reference.toLowerCase()}`, lang)]),
);
---

<section class="bg-card border-b border-clay py-10 sm:py-14">
  <div class="container">
    <div class="max-w-2xl">
      <div class="text-[12px] uppercase tracking-[0.14em] font-semibold text-primary flex items-center gap-2">
        <span class="w-6 h-px bg-primary"></span>Annonces
      </div>
      <h1 class="font-serif font-light text-[clamp(32px,5vw,56px)] leading-tight tracking-tight mt-2">
        {t('page.listings.title', lang)}
      </h1>
      <p class="mt-3 text-muted-foreground">{t('page.listings.subtitle', lang)}</p>
    </div>
  </div>
</section>

<ListingsView
  client:only="react"
  properties={properties}
  cities={cities}
  hrefByRef={hrefByRef}
  lang={lang}
/>

<!-- Static SSR fallback for SEO + no-JS — same list, no map.
     React island replaces it once hydrated. -->
<noscript>
  <div class="container py-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {properties.map((p) => (
        <a href={hrefByRef[p.reference]} class="block rounded-2xl border border-clay bg-card overflow-hidden">
          <div class="aspect-[16/10] bg-ink">
            {p.images[0] && <img src={p.images[0]} alt={p.title} class="w-full h-full object-cover" />}
          </div>
          <div class="p-4">
            <div class="font-serif text-lg">{p.title}</div>
            <div class="text-sm text-muted-foreground mt-1">{p.city} · {p.quartier}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</noscript>

<CompareBar client:idle lang={lang} />
