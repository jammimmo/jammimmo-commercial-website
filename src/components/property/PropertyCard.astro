---
import type { PublicProperty } from '@/types/property';
import { formatRentalPrice, formatLocation } from '@/lib/format';
import { formatPublicRef } from '@/lib/reference';
import { getStatusBadge, getTransactionBadge, statusLabel, transactionLabel } from '@/lib/status';
import { localizedPath, t, type Lang } from '@/lib/i18n';
import CompareToggle from './CompareToggle.tsx';
import FavoriteToggle from './FavoriteToggle.tsx';
import { youtubeIdFromUrl, youtubeThumb } from '@/lib/youtube';

interface Props {
  property: PublicProperty;
  lang: Lang;
  /** When true, hide the "Comparer" toggle (e.g. on the comparer page itself). */
  hideCompare?: boolean;
  /** Reveal animation delay class (d1/d2/d3). */
  delay?: '' | 'd1' | 'd2' | 'd3';
}

const { property: p, lang, hideCompare = false, delay = '' } = Astro.props;

const statusBadge = getStatusBadge(p.status);
const transactionBadge = getTransactionBadge(p.transaction_type);

// Split thumbnail strategy:
//   • If the property has BOTH a video tour and uploaded photos → split the
//     4:3 tile: left half = video thumbnail with a play badge; right half =
//     2×2 mosaic of the first 4 photos.
//   • If only one of them → single image fills the whole tile (video thumb
//     as fallback). Aspect ratio is unchanged either way (4:3 outer).
const videoId = youtubeIdFromUrl(p.video_links[0]);
const videoThumb = youtubeThumb(p.video_links[0]);
const split = !!videoId && p.images.length >= 1;
const mosaicImgs = p.images.slice(0, 4);
const heroImage: string | null = split ? null : (p.images[0] ?? videoThumb);
const heroImageIsYoutube = !split && !p.images[0] && heroImage !== null;
const href = localizedPath(`/biens/${p.reference.toLowerCase()}`, lang);

// Placeholder gradient when no image
const palette: Array<[string, string]> = [
  ['#2632A0', '#0E1450'],
  ['#F08826', '#a04f0a'],
  ['#1B2378', '#080C3C'],
  ['#F5A552', '#b94e10'],
];
const hash = (p.reference.charCodeAt(0) + p.reference.charCodeAt(p.reference.length - 1)) % palette.length;
const [phA, phB] = palette[hash]!;
---

<article
  class:list={['group reveal relative flex flex-col bg-card rounded-[22px] overflow-hidden border border-clay transition-all duration-500 hover:translate-y-[-6px] hover:shadow-[0_40px_80px_-40px_hsl(var(--ink)/.3)]', delay]}
  data-property-ref={p.reference}
>
  <a href={href} class="block relative aspect-[4/3] overflow-hidden bg-ink" aria-label={p.title}>
    {split ? (
      <!-- Split thumb: video LEFT, 2×2 photo mosaic RIGHT. Aspect-[4/3]
           kept on the outer link; inner grid fills it absolutely. -->
      <div class="absolute inset-0 grid grid-cols-2 gap-1 bg-ink">
        <!-- LEFT: video — starts as the YouTube thumbnail + play badge; on
             first scroll-into-view a muted/looped/autoplay iframe replaces
             the image (see <script> at bottom of file). -->
        <div
          class="relative overflow-hidden"
          data-video-thumb
          data-yt-id={videoId!}
        >
          <img
            src={videoThumb}
            alt={`Visite vidéo — ${p.title}`}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <span class="absolute inset-0 bg-black/25 transition-colors group-hover:bg-black/15 pointer-events-none"></span>
          <span class="absolute inset-0 grid place-items-center pointer-events-none" aria-hidden="true">
            <span class="w-12 h-12 grid place-items-center rounded-full bg-white/95 text-primary shadow-md">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </span>
        </div>
        <!-- RIGHT: 2×2 photo mosaic (fills with whatever photos exist) -->
        <div class="grid grid-cols-2 grid-rows-2 gap-1">
          {Array.from({ length: 4 }).map((_, i) => {
            const src = mosaicImgs[i] ?? mosaicImgs[mosaicImgs.length - 1];
            return (
              <div class="relative overflow-hidden bg-ink">
                <img
                  src={src}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            );
          })}
        </div>
      </div>
    ) : heroImage ? (
      <>
        <img
          src={heroImage}
          alt={p.title}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        {heroImageIsYoutube && (
          <span class="absolute bottom-3.5 right-3.5 z-[2] inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10.5px] font-semibold bg-black/55 text-white backdrop-blur" aria-hidden="true">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            {t('common.videoTour', lang)}
          </span>
        )}
      </>
    ) : (
      <div
        class="absolute inset-0 grid place-items-center text-white/85"
        style={`background: repeating-linear-gradient(135deg, rgba(255,255,255,.05) 0 12px, transparent 12px 24px), linear-gradient(135deg, ${phA}, ${phB});`}
      >
        <span class="font-mono text-[11.5px] tracking-[0.12em] uppercase bg-black/40 px-3 py-1.5 rounded border border-white/20">
          {p.type} · {p.quartier || p.city}
        </span>
      </div>
    )}

    {/* Top-left stack: transaction (vente/location) + status badges so the
        top-right corner stays clear for the favorite heart, à la Zillow. */}
    <div class="absolute top-3.5 left-3.5 flex flex-wrap gap-1.5 z-[2] max-w-[calc(100%-72px)]">
      <span class:list={['px-3 py-1.5 rounded-full text-[11.5px] font-semibold tracking-wide shadow-md backdrop-blur', transactionBadge.badgeClass]}>
        {transactionLabel(p.transaction_type, lang)}
      </span>
      <span class:list={['inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[11px] font-semibold tracking-wide uppercase shadow-md backdrop-blur', statusBadge.badgeClass]}>
        <span aria-hidden>{statusBadge.emoji}</span>{statusLabel(p.status, lang)}
      </span>
    </div>

    {p.tags.length > 0 && (
      <div class="absolute bottom-3.5 left-3.5 flex gap-1.5 z-[2]">
        {p.tags.slice(0, 2).map((tag) => (
          <span class="px-2.5 py-1 rounded-full text-[10.5px] font-semibold bg-black/55 text-white backdrop-blur">
            {tag}
          </span>
        ))}
      </div>
    )}

    {p.images.length > 0 && (
      <span class="absolute bottom-3.5 right-3.5 z-[2] inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10.5px] font-semibold bg-black/55 text-white backdrop-blur">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><rect x="3" y="3" width="14" height="14" rx="2" /><path d="M7 21h12a2 2 0 0 0 2-2V9" /></svg>
        {p.images.length}
      </span>
    )}
  </a>

  {/* Heart toggle — sibling of <a> (NOT inside) to avoid nesting interactive
      elements. Positioned absolute against the article (which is `relative`)
      so it lands on the thumbnail's top-right corner. `z-[3]` keeps it above
      the badges (`z-[2]`). */}
  <FavoriteToggle
    client:visible
    reference={p.reference}
    title={p.title}
    lang={lang}
    variant="icon"
  />

  <div class="flex flex-col gap-2.5 p-6">
    <div class="flex items-center justify-between gap-2">
      <span class="text-[12.5px] font-semibold tracking-[0.08em] uppercase text-muted-foreground">
        {formatLocation(p.city, p.quartier)}
      </span>
      <span class="text-[11px] font-mono text-muted-foreground/70">{formatPublicRef(p.reference)}</span>
    </div>

    <a href={href} class="block group/title">
      <h3 class="font-serif font-normal text-[22px] tracking-tight leading-tight m-0 group-hover/title:text-primary transition">
        {p.title}
      </h3>
    </a>

    <div class="flex flex-wrap gap-3.5 text-[13px] text-muted-foreground mt-1">
      {p.bedrooms > 0 && <span class="inline-flex items-center gap-1.5">🛏 {p.bedrooms} ch.</span>}
      {p.surface > 0 && <span class="inline-flex items-center gap-1.5">📐 {p.surface} m²</span>}
      {p.commodities.slice(0, 2).map((c) => <span class="inline-flex items-center gap-1.5">✓ {c}</span>)}
    </div>

    <div class="flex items-baseline justify-between mt-3 pt-3.5 border-t border-clay">
      <div class="font-serif text-[22px] font-normal tracking-tight">
        <span class="bidi-ltr">{formatRentalPrice(p.price, p.transaction_type)}</span>
        {p.negotiable && (
          <span class="ml-2 text-[11px] font-sans font-semibold text-terra align-middle">{t('property.price.negotiable', lang)}</span>
        )}
      </div>
      <a href={href} class="text-[12.5px] font-semibold text-primary inline-flex items-center gap-1.5">
        {t('common.details', lang)} <span aria-hidden>↗</span>
      </a>
    </div>

    {!hideCompare && <CompareToggle client:visible reference={p.reference} title={p.title} lang={lang} />}
  </div>
</article>

<script>
  // Lazy autoplay for split-thumb video tiles. Astro hoists this once for
  // the whole bundle even when PropertyCard is rendered N times.
  //
  // Mobile autoplay constraints (iOS Safari + Android Chrome) require ALL
  // of: muted, playsinline=1, and the iframe's `allow` attribute to grant
  // autoplay. Even with those, some mobile browsers still need a nudge —
  // we send a postMessage("playVideo") on iframe load as a belt-and-
  // suspenders, which requires enablejsapi=1.
  function mount(el: HTMLElement) {
    if (el.dataset.ytMounted) return;
    const id = el.dataset.ytId;
    if (!id) return;

    const params = new URLSearchParams({
      autoplay: '1',
      mute: '1',
      loop: '1',
      playlist: id,
      controls: '0',
      modestbranding: '1',
      playsinline: '1',
      rel: '0',
      iv_load_policy: '3',
      disablekb: '1',
      enablejsapi: '1',
    });

    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube-nocookie.com/embed/${id}?${params.toString()}`;
    iframe.title = 'Visite vidéo';
    iframe.setAttribute('allow', 'autoplay; encrypted-media; picture-in-picture');
    iframe.setAttribute('allowfullscreen', '');
    iframe.setAttribute('playsinline', '');
    iframe.setAttribute('webkit-playsinline', '');
    iframe.setAttribute('muted', '');
    iframe.setAttribute('frameborder', '0');
    iframe.setAttribute('referrerpolicy', 'strict-origin-when-cross-origin');
    iframe.setAttribute(
      'sandbox',
      'allow-scripts allow-same-origin allow-presentation allow-popups allow-popups-to-escape-sandbox',
    );
    iframe.style.cssText =
      'position:absolute;inset:0;width:100%;height:100%;border:0;pointer-events:none;';

    iframe.addEventListener('load', () => {
      // Force play via postMessage in case the URL params alone don't
      // trigger autoplay on mobile. Sends the IFrame API "playVideo"
      // command. Wrapped in try/catch because cross-origin restrictions
      // sometimes throw before the iframe is fully initialised.
      try {
        iframe.contentWindow?.postMessage(
          JSON.stringify({ event: 'command', func: 'playVideo', args: [] }),
          '*',
        );
        iframe.contentWindow?.postMessage(
          JSON.stringify({ event: 'command', func: 'mute', args: [] }),
          '*',
        );
      } catch {
        /* swallow */
      }
    });

    el.insertBefore(iframe, el.firstChild?.nextSibling ?? null);
    // Fade the static image + play badge so we don't double-stack visuals.
    requestAnimationFrame(() => {
      const img = el.querySelector('img');
      if (img) img.style.opacity = '0';
      el.querySelectorAll(':scope > span').forEach((s) => {
        (s as HTMLElement).style.opacity = '0';
      });
    });
    el.dataset.ytMounted = '1';
  }

  const thumbs = document.querySelectorAll<HTMLElement>('[data-video-thumb]:not([data-yt-mounted])');
  if (thumbs.length > 0) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          mount(entry.target as HTMLElement);
          io.unobserve(entry.target);
        }
      },
      // 400 px margin = iframe is loading before the card hits the
      // viewport, so on slow mobile networks the video has time to
      // start playing by the time the user actually sees it.
      // threshold 0 fires as soon as any pixel intersects.
      { rootMargin: '400px', threshold: 0 },
    );
    thumbs.forEach((el) => io.observe(el));
  }
</script>
