---
import { buildHreflangLinks, LANGS, type Lang } from '@/lib/i18n';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  canonical?: string;
  /** Emit `noindex, follow` instead of indexable robots (404, dead-end pages). */
  noindex?: boolean;
}

const {
  lang,
  title,
  description,
  image = '/og-default.png',
  imageAlt = 'Jamm Immobilier',
  type = 'website',
  canonical,
  noindex = false,
} = Astro.props;

/** Open Graph locales for all 6 languages. NB: og:locale follows Facebook's
 *  own supported-locale list (NOT strict ISO-3166) — `ar_AR` is Facebook's
 *  generic Arabic and is the recognized value (locked by the multilang-rtl
 *  e2e). JSON-LD `inLanguage` separately uses BCP-47 `ar-SN`. */
const OG_LOCALE = { fr: 'fr_SN', en: 'en_US', wo: 'wo_SN', es: 'es_ES', it: 'it_IT', ar: 'ar_AR' } as const;

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? 'https://jammimmo.com';

/**
 * Normalize a URL to a trailing slash on its path. Cloudflare Pages serves
 * every route with a trailing slash (308-redirecting the slash-less form), and
 * the sitemap uses trailing slashes — so canonical + hreflang + og:url must
 * match that final 200 URL, not the 308 source. Skip URLs carrying a query or
 * fragment (e.g. the SearchAction target).
 */
const withSlash = (u: string): string =>
  /[?#]/.test(u) || u.endsWith('/') ? u : `${u}/`;

const fullCanonical = withSlash(canonical ?? `${siteOrigin}${Astro.url.pathname}`);
const fullImage = image.startsWith('http') ? image : `${siteOrigin}${image}`;
const hreflangs = buildHreflangLinks(Astro.url.pathname, siteOrigin).map((h) => ({
  ...h,
  href: withSlash(h.href),
}));
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={fullCanonical} />

{hreflangs.map((h) => <link rel="alternate" hreflang={h.hreflang} href={h.href} />)}

<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content={fullImage.endsWith('.png') ? 'image/png' : 'image/jpeg'} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:url" content={fullCanonical} />
<meta property="og:site_name" content="Jamm Immobilier" />
<meta property="og:locale" content={OG_LOCALE[lang] ?? 'fr_SN'} />
{LANGS.filter((l) => l !== lang).map((l) => <meta property="og:locale:alternate" content={OG_LOCALE[l]} />)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImage} />
<meta name="twitter:image:alt" content={imageAlt} />

<meta name="theme-color" content="#2632A0" />
<meta
  name="robots"
  content={noindex
    ? 'noindex, follow'
    : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
/>
<meta name="format-detection" content="telephone=no" />
