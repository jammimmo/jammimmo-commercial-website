---
/**
 * Global Organization + WebSite + RealEstateAgent JSON-LD, emitted only
 * on homepages. Wins the Knowledge Panel for branded queries
 * ("Jamm Immobilier", "Jamm Immo") and unlocks the SERP search-box
 * sitelink for "site:jammimmo.com X" patterns.
 *
 * SearchAction template points at /biens?q={query} so Google can deep-link
 * the search-box directly into the listings page.
 */
import { SITE } from '@/lib/site-config';
import type { Lang } from '@/lib/i18n';

interface Props {
  lang: Lang;
  /**
   * Whether to include the WebSite + SearchAction node. Only the homepage
   * should (the search-box sitelink is a homepage feature). The Organization
   * node is emitted on EVERY page so the `#organization` @id referenced by
   * property/geo pages (broker/seller/publisher) always resolves.
   */
  includeWebsite?: boolean;
}
const { lang, includeWebsite = false } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://jammimmo.com';
// BCP-47 tags for all 6 site languages (es/it/ar previously fell through to
// 'wo-SN', mislabelling those homepages as Wolof to Google + AI engines).
const LD_LANG = { fr: 'fr-SN', en: 'en-US', wo: 'wo-SN', es: 'es-ES', it: 'it-IT', ar: 'ar-SN' } as const;
const inLanguage = LD_LANG[lang] ?? 'fr-SN';

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Organization', 'RealEstateAgent'],
      '@id': `${siteUrl}/#organization`,
      name: SITE.agencyName,
      url: siteUrl,
      logo: `${siteUrl}/og-default.png`,
      image: `${siteUrl}/og-default.png`,
      telephone: SITE.phoneE164,
      email: SITE.email,
      priceRange: '$$',
      currenciesAccepted: 'XOF',
      knowsLanguage: ['fr', 'en', 'wo', 'es', 'it', 'ar'],
      areaServed: [
        { '@type': 'Country', name: 'Sénégal' },
        { '@type': 'City', name: 'Dakar' },
        { '@type': 'City', name: 'Saly' },
        { '@type': 'City', name: 'Mbour' },
        { '@type': 'City', name: 'Saint-Louis' },
        { '@type': 'City', name: 'Thiès' },
      ],
      address: {
        '@type': 'PostalAddress',
        streetAddress: SITE.address.street,
        addressLocality: SITE.address.locality,
        addressRegion: SITE.address.region,
        addressCountry: SITE.address.country,
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: SITE.geo.lat,
        longitude: SITE.geo.lng,
      },
      hasMap: `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
        `${SITE.agencyName}, ${SITE.address.street}, ${SITE.address.locality}, Sénégal`,
      )}`,
      openingHoursSpecification: SITE.hours.spec.map((s) => ({
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: s.days,
        opens: s.opens,
        closes: s.closes,
      })),
      contactPoint: [
        {
          '@type': 'ContactPoint',
          contactType: 'customer service',
          telephone: SITE.phoneE164,
          email: SITE.email,
          availableLanguage: ['French', 'English', 'Wolof', 'Spanish', 'Italian', 'Arabic'],
          areaServed: 'SN',
        },
      ],
      sameAs: Object.values(SITE.socials).filter(Boolean),
    },
    ...(includeWebsite ? [{
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: SITE.agencyName,
      inLanguage,
      publisher: { '@id': `${siteUrl}/#organization` },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${siteUrl}/biens?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    }] : []),
  ],
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(graph)}></script>
