---
import BrandMark from './BrandMark.astro';
import { t, type Lang, localizedPath } from '@/lib/i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
const p = (path: string) => localizedPath(path, lang);
---

<footer class="bg-[hsl(var(--primary)/.96)] text-white py-20">
  <div class="container">
    <div class="grid gap-12 md:grid-cols-[1.4fr_repeat(3,1fr)] mb-12">
      <div>
        <a href={p('/')} class="flex items-center gap-3 font-extrabold text-white">
          <BrandMark size={42} />
          <span class="leading-none">
            <span class="block">JAMM IMMOBILIER</span>
            <small class="block font-medium text-[10px] mt-1 opacity-60 tracking-[0.12em] uppercase">
              {t('site.tagline', lang)}
            </small>
          </span>
        </a>
        <p class="text-[14.5px] leading-relaxed text-white/65 mt-5 max-w-[36ch]">
          {t('footer.about', lang)}
        </p>
        <div class="flex gap-2.5 mt-5">
          <a aria-label="Instagram" href="#" class="w-9 h-9 rounded-full bg-white/8 grid place-items-center hover:bg-secondary transition">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
          <a aria-label="Facebook" href="#" class="w-9 h-9 rounded-full bg-white/8 grid place-items-center hover:bg-secondary transition">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13 22v-8h3l1-4h-4V7.5c0-1.1.5-2 2-2h2V2h-3c-3 0-5 2-5 5v3H6v4h3v8z"/></svg>
          </a>
          <a aria-label="WhatsApp" href="https://wa.me/221770000000" class="w-9 h-9 rounded-full bg-white/8 grid place-items-center hover:bg-secondary transition">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.3A10 10 0 1 0 12 2zm5.6 14.2c-.2.6-1.3 1.2-1.8 1.3-.5.1-1.1.1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.7-4-4.8-4.2-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.3-.3.6-.4.8-.4h.6c.2 0 .4 0 .6.5.2.5.7 1.7.7 1.8.1.1.1.3 0 .5l-.3.4-.4.5c-.1.1-.3.3-.1.6.2.3.8 1.3 1.8 2.1 1.2 1.1 2.2 1.4 2.5 1.5.3.1.5.1.7-.1.2-.2.7-.9 1-1.2.2-.3.4-.2.7-.1.3.1 1.7.8 2 1 .3.1.5.2.6.3.1.2.1.7-.1 1.4z"/></svg>
          </a>
          <a aria-label="LinkedIn" href="#" class="w-9 h-9 rounded-full bg-white/8 grid place-items-center hover:bg-secondary transition">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.1c.5-1 1.9-2.1 3.9-2.1 4.2 0 5 2.7 5 6.3V21h-4v-5.2c0-1.2 0-2.8-1.7-2.8s-2 1.3-2 2.7V21h-4z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h6 class="text-[11px] tracking-[0.14em] uppercase text-white/50 font-semibold mb-4">{t('footer.services', lang)}</h6>
        <ul class="space-y-2.5 text-[14.5px] text-white/85">
          <li><a href={p('/biens?transaction=Vente')} class="hover:text-secondary">{t('service.sale.title', lang)}</a></li>
          <li><a href={p('/biens?transaction=Location')} class="hover:text-secondary">{t('service.rent.title', lang)}</a></li>
          <li><a href={`${p('/')}#services`} class="hover:text-secondary">{t('service.manage.title', lang)}</a></li>
          <li><a href={`${p('/')}#services`} class="hover:text-secondary">{t('service.project.title', lang)}</a></li>
        </ul>
      </div>
      <div>
        <h6 class="text-[11px] tracking-[0.14em] uppercase text-white/50 font-semibold mb-4">{t('footer.discover', lang)}</h6>
        <ul class="space-y-2.5 text-[14.5px] text-white/85">
          <li><a href={p('/biens')} class="hover:text-secondary">{t('properties.cta.viewAll', lang)}</a></li>
          <li><a href={`${p('/')}#pourquoi`} class="hover:text-secondary">{t('why.title', lang)}</a></li>
          <li><a href={p('/comparer')} class="hover:text-secondary">{t('page.compare.title', lang)}</a></li>
          <li><a href={p('/contact')} class="hover:text-secondary">{t('nav.contact', lang)}</a></li>
        </ul>
      </div>
      <div>
        <h6 class="text-[11px] tracking-[0.14em] uppercase text-white/50 font-semibold mb-4">{t('footer.contact', lang)}</h6>
        <ul class="space-y-2.5 text-[14.5px] text-white/85">
          <li><a href="tel:+221770000000" class="hover:text-secondary">+221 77 000 00 00</a></li>
          <li><a href="mailto:contact@jammimmo.com" class="hover:text-secondary">contact@jammimmo.com</a></li>
          <li>Fann Résidence, Dakar</li>
          <li>Lun–Ven · 9h–18h</li>
        </ul>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 pt-7 border-t border-white/12 text-[13px] text-white/55">
      <span>{t('footer.copy', lang)}</span>
      <span class="flex gap-5">
        <a href="#" class="hover:text-white">{t('footer.legal', lang)}</a>
        <a href="#" class="hover:text-white">{t('footer.privacy', lang)}</a>
        <a href="#" class="hover:text-white">{t('footer.cookies', lang)}</a>
      </span>
    </div>
  </div>
</footer>
