---
import BrandMark from './BrandMark.astro';
import LanguageSwitcher from './LanguageSwitcher.tsx';
import { t, type Lang, localizedPath, LANGS } from '@/lib/i18n';
import { SITE, TEL_URI, MAPS_DIRECTIONS_URI } from '@/lib/site-config';

interface Props {
  lang: Lang;
  /** When true, the nav stays opaque from the top (e.g. on /biens pages). */
  solid?: boolean;
}
const { lang, solid = false } = Astro.props;
const p = (path: string) => localizedPath(path, lang);

// Desktop navigation: 4 top-level entries (2 of them dropdowns) instead of
// 8 flat links — keeps the bar airy and readable from `md` up. Dropdown
// triggers reuse the first child's key as their label, so NO new i18n keys
// are introduced (constraint: reuse existing nav.* keys only).
type NavItem = { href: string; key: string };
type NavEntry = NavItem | { key: string; children: NavItem[] };

const navEntries: NavEntry[] = [
  { href: p('/biens'), key: 'nav.listings' },           // buyer core — always visible
  { key: 'nav.services', children: [                     // "Agence" group
    { href: `${p('/')}#services`, key: 'nav.services' },
    { href: `${p('/')}#pourquoi`, key: 'nav.why' },
    { href: `${p('/')}#process`,  key: 'nav.process' },
  ]},
  { key: 'nav.owners', children: [                        // "Vendre & confier" group
    { href: p('/proprietaires'), key: 'nav.owners' },
    { href: p('/estimation'),    key: 'nav.estimate' },
    { href: p('/partenaires'),   key: 'nav.partners' },
  ]},
  { href: p('/contact'), key: 'nav.contact' },
];

// Flat list derived from the grouped structure — used only by the mobile
// drawer, whose vertical-scroll UX is fine showing all links at one level.
const navLinks: NavItem[] = navEntries.flatMap((e) =>
  'children' in e ? e.children : [e],
);

// Secondary discover links for the mobile drawer (the newer pages). The buyer
// budget tool lives here (drawer-only) — NOT as a desktop top-level entry, to
// keep the bar at 4 entries (see navEntries comment above).
const quickLinks: Array<{ href: string; key: string }> = [
  { href: p('/immobilier'), key: 'geo.hub.eyebrow' },
  { href: p('/budget'),     key: 'nav.budget' },
  { href: p('/trouver-mon-bien'), key: 'nav.match' },
  { href: p('/frais-acquisition'), key: 'nav.frais' },
  { href: p('/rentabilite'), key: 'nav.rentabilite' },
  { href: p('/securite-fonciere'), key: 'nav.safety' },
  { href: p('/favoris'),    key: 'page.favorites.title' },
  { href: p('/comparer'),   key: 'page.compare.title' },
];

// Language pills: same page, swapped locale. Strip the current lang prefix
// then re-localize so e.g. /en/biens → /biens (FR) or /wo/biens (WO).
const cleanPath = Astro.url.pathname.replace(/^\/(en|wo|es|it|ar)(?=\/|$)/, '') || '/';
const langItems = LANGS.map((code) => ({
  code,
  label: code.toUpperCase(),
  href: localizedPath(cleanPath, code),
}));
---

<nav
  id="nav"
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-colors duration-300',
    solid ? 'bg-background/95 backdrop-blur shadow-sm text-foreground' : 'text-white',
  ]}
  data-solid={solid ? 'true' : 'false'}
>
  {!solid && (
    <!-- Legibility scrim for the transparent (over-hero) state. Subtle dark
         vignette so the white logo/links stay readable even in the brief
         frame where a deep-link (e.g. /#services) lands scrolled into a
         light section before the scroll script flips the nav to solid.
         Hidden once the nav goes solid (see apply() below). -->
    <div
      data-nav-scrim
      class="absolute inset-0 -z-[1] bg-gradient-to-b from-black/45 via-black/15 to-transparent pointer-events-none transition-opacity duration-300"
      aria-hidden="true"
    ></div>
  )}
  <div class="container flex items-center justify-between h-[78px]">
    <a href={p('/')} class="flex items-center gap-3 font-extrabold tracking-wide text-[17px]">
      <BrandMark size={40} />
      <span class="leading-none">
        <span class="block">JAMM IMMOBILIER</span>
        <small class="block font-medium text-[10px] opacity-85 mt-1 tracking-[0.1em] uppercase">
          {t('site.tagline', lang)}
        </small>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-6 lg:gap-7 text-[14.5px] font-medium">
      {navEntries.map((e) => (
        'children' in e ? (
          // Dropdown group — opens on hover AND focus-within so it works with
          // the keyboard too; the panel mirrors LanguageSwitcher's styling for
          // visual consistency. CSS-only: no JS / no hydration needed.
          <div class="relative group/dd">
            <button
              type="button"
              aria-haspopup="true"
              class="inline-flex items-center gap-1 py-1.5 group-hover/dd:opacity-90 transition-opacity"
            >
              {t(e.key, lang)}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true" class="transition-transform duration-200 group-hover/dd:rotate-180 group-focus-within/dd:rotate-180">
                <path d="M6 9l6 6 6-6" />
              </svg>
            </button>
            {/* Invisible bridge: covers the gap between trigger and panel so
                the menu doesn't close as the cursor crosses the offset. */}
            <div class="absolute left-0 top-full h-3 w-full" aria-hidden="true"></div>
            <div
              class="absolute left-0 top-[calc(100%+0.5rem)] min-w-[230px] rounded-xl border border-clay bg-card text-foreground shadow-xl overflow-hidden p-1.5 opacity-0 invisible translate-y-1 transition-all duration-200 group-hover/dd:opacity-100 group-hover/dd:visible group-hover/dd:translate-y-0 group-focus-within/dd:opacity-100 group-focus-within/dd:visible group-focus-within/dd:translate-y-0"
            >
              {e.children.map((c) => (
                <a
                  href={c.href}
                  class="block px-3.5 py-2.5 rounded-lg text-sm hover:bg-accent hover:text-accent-foreground transition"
                >{t(c.key, lang)}</a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={e.href}
            class="relative py-1.5 after:absolute after:left-0 after:-bottom-0.5 after:h-px after:w-0 after:bg-current after:transition-[width] after:duration-300 hover:after:w-full"
          >{t(e.key, lang)}</a>
        )
      ))}
    </div>

    <div class="flex items-center gap-3">
      <LanguageSwitcher client:idle lang={lang} pathname={Astro.url.pathname} />
      <a
        href={p('/contact')}
        class="group/cta relative overflow-hidden hidden sm:inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-secondary text-secondary-foreground font-semibold text-sm shadow-[0_6px_22px_-6px_hsl(var(--secondary)/.5)] hover:translate-y-[-1px] transition-transform"
      >
        <span class="pointer-events-none absolute inset-0 -translate-x-full group-hover/cta:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/25 to-transparent" aria-hidden="true"></span>
        {t('nav.cta', lang)}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="hidden sm:block rtl-flip">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>

      <!-- Mobile menu trigger — visible <md -->
      <button
        type="button"
        class="md:hidden w-11 h-11 grid place-items-center rounded-full bg-white/10 hover:bg-white/20 text-current transition"
        aria-label={t('nav.openMenu', lang)}
        aria-controls="mobile-nav"
        aria-expanded="false"
        data-mobile-nav-trigger
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile drawer — hidden below md and behind a JS-toggled class. -->
<div
  id="mobile-nav"
  class="md:hidden fixed inset-0 z-[60] pointer-events-none"
  data-mobile-nav
  aria-hidden="true"
>
  <div class="absolute inset-0 bg-black/55 opacity-0 transition-opacity duration-300" data-mobile-nav-backdrop></div>
  <aside
    role="dialog"
    aria-modal="true"
    aria-label={t('nav.openMenu', lang)}
    class="absolute top-0 right-0 bottom-0 w-[min(90vw,390px)] bg-card text-foreground shadow-2xl translate-x-full transition-transform duration-300 flex flex-col overflow-hidden"
    data-mobile-nav-panel
  >
    {/* ── Fioriture: soft Sahel sun-glow + woven dot texture behind content ── */}
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div
        class="absolute -top-20 -right-16 w-60 h-60 rounded-full opacity-[0.16]"
        style="background: radial-gradient(circle at 38% 38%, hsl(var(--secondary)), hsl(var(--ochre)) 45%, transparent 72%); filter: blur(6px);"
      ></div>
      <div
        class="absolute -bottom-24 -left-20 w-64 h-64 rounded-full opacity-[0.10]"
        style="background: radial-gradient(circle, hsl(var(--primary)), transparent 70%); filter: blur(10px);"
      ></div>
      <div
        class="absolute inset-0 opacity-60"
        style="background-image: var(--sahel-weave-bg); background-size: var(--sahel-weave-size); background-position: var(--sahel-weave-pos);"
      ></div>
    </div>

    {/* Brand header */}
    <div class="relative z-10 flex items-center justify-between px-5 h-[78px] shrink-0 after:absolute after:left-5 after:right-5 after:bottom-0 after:h-px after:bg-gradient-to-r after:from-secondary/60 after:via-clay after:to-transparent">
      <a href={p('/')} class="flex items-center gap-2.5">
        <BrandMark size={34} />
        <span class="leading-none">
          <span class="block font-extrabold tracking-wide text-[14px]">JAMM IMMOBILIER</span>
          <small class="block text-[10px] uppercase tracking-[0.1em] text-foreground/70 mt-1">{t('site.tagline', lang)}</small>
        </span>
      </a>
      <button
        type="button"
        class="w-11 h-11 grid place-items-center rounded-full bg-muted hover:bg-clay transition shrink-0"
        aria-label={t('nav.closeMenu', lang)}
        data-mobile-nav-close
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>

    {/* Scrollable content */}
    <div class="relative z-10 flex-1 overflow-y-auto px-5 py-5 flex flex-col gap-7">
      {/* Primary nav */}
      <nav aria-label="Navigation principale">
        <ul class="flex flex-col gap-0.5 text-[16.5px] font-medium">
          {navLinks.map((l) => (
            <li>
              <a href={l.href} class="group flex items-center justify-between px-4 py-3.5 rounded-xl hover:bg-accent hover:text-accent-foreground transition">
                <span>{t(l.key, lang)}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="text-muted-foreground group-hover:text-accent-foreground group-hover:translate-x-0.5 transition rtl-flip" aria-hidden="true"><path d="M9 6l6 6-6 6" /></svg>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {/* Discover (secondary) */}
      <div>
        <p class="flex items-center gap-2 px-1 mb-2.5 text-[11px] uppercase tracking-[0.14em] font-semibold text-secondary-strong">
          <span class="w-5 h-px bg-gradient-to-r from-secondary-strong to-transparent" aria-hidden="true"></span>
          {t('footer.discover', lang)}
        </p>
        <div class="flex flex-wrap gap-2">
          {quickLinks.map((l) => (
            <a href={l.href} class="px-3.5 py-2 rounded-full text-[13px] font-medium bg-muted border border-clay hover:bg-accent hover:text-accent-foreground hover:border-primary transition">
              {t(l.key, lang)}
            </a>
          ))}
        </div>
      </div>

      {/* Direct contact actions */}
      <div>
        <p class="flex items-center gap-2 px-1 mb-2.5 text-[11px] uppercase tracking-[0.14em] font-semibold text-secondary-strong">
          <span class="w-5 h-px bg-gradient-to-r from-secondary-strong to-transparent" aria-hidden="true"></span>
          {t('contact.tag', lang)}
        </p>
        <div class="grid grid-cols-3 gap-2">
          <a href={TEL_URI} data-track="phone.tapped" data-track-prop-source="drawer" class="flex flex-col items-center gap-1.5 py-3 rounded-2xl bg-primary/5 border border-clay hover:border-primary text-primary transition">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span class="text-[11px] font-semibold">{t('property.detail.call', lang)}</span>
          </a>
          <a href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer" data-track="whatsapp.tapped" data-track-prop-source="drawer" class="flex flex-col items-center gap-1.5 py-3 rounded-2xl bg-emerald/10 border border-emerald/25 hover:border-emerald text-emerald transition">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.3A10 10 0 1 0 12 2zm5.6 14.2c-.2.6-1.3 1.2-1.8 1.3-.5.1-1.1.1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.7-4-4.8-4.2-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.3-.3.6-.4.8-.4h.6c.2 0 .4 0 .6.5.2.5.7 1.7.7 1.8.1.1.1.3 0 .5l-.3.4-.4.5c-.1.1-.3.3-.1.6.2.3.8 1.3 1.8 2.1 1.2 1.1 2.2 1.4 2.5 1.5.3.1.5.1.7-.1.2-.2.7-.9 1-1.2.2-.3.4-.2.7-.1.3.1 1.7.8 2 1 .3.1.5.2.6.3.1.2.1.7-.1 1.4z"/></svg>
            <span class="text-[11px] font-semibold">WhatsApp</span>
          </a>
          <a href={MAPS_DIRECTIONS_URI} target="_blank" rel="noopener noreferrer" data-track="directions.tapped" data-track-prop-source="drawer" class="flex flex-col items-center gap-1.5 py-3 rounded-2xl bg-secondary/10 border border-secondary/25 hover:border-secondary text-secondary-strong transition">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
            <span class="text-[11px] font-semibold">Itinéraire</span>
          </a>
        </div>
        <a href={TEL_URI} class="mt-3 block text-center font-serif text-[19px] tracking-tight hover:text-primary transition">{SITE.phoneDisplay}</a>
        <p class="mt-1 text-center text-[12px] text-muted-foreground">{SITE.hours.display}</p>
      </div>

      {/* Language + socials */}
      <div class="flex items-center justify-between gap-4 pt-1">
        <div class="flex gap-1.5" role="group" aria-label="Langue">
          {langItems.map((l) => (
            <a
              href={l.href}
              hreflang={l.code}
              aria-current={l.code === lang ? 'true' : undefined}
              class:list={[
                'w-10 h-10 grid place-items-center rounded-full text-[12.5px] font-bold tracking-[0.04em] border transition',
                l.code === lang
                  ? 'bg-primary text-primary-foreground border-primary shadow-[0_0_0_4px_hsl(var(--primary)/.14)]'
                  : 'bg-muted border-clay hover:border-primary text-foreground',
              ]}
            >{l.label}</a>
          ))}
        </div>
        <div class="flex items-center gap-2">
          {SITE.socials.instagram && (
            <a aria-label="Instagram" href={SITE.socials.instagram} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-muted border border-clay grid place-items-center hover:border-primary hover:text-primary transition">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
            </a>
          )}
          {SITE.socials.facebook && (
            <a aria-label="Facebook" href={SITE.socials.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-muted border border-clay grid place-items-center hover:border-primary hover:text-primary transition">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M13 22v-8h3l1-4h-4V7.5c0-1.1.5-2 2-2h2V2h-3c-3 0-5 2-5 5v3H6v4h3v8z"/></svg>
            </a>
          )}
          {SITE.socials.linkedin && (
            <a aria-label="LinkedIn" href={SITE.socials.linkedin} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-muted border border-clay grid place-items-center hover:border-primary hover:text-primary transition">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.1c.5-1 1.9-2.1 3.9-2.1 4.2 0 5 2.7 5 6.3V21h-4v-5.2c0-1.2 0-2.8-1.7-2.8s-2 1.3-2 2.7V21h-4z"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    {/* CTA footer */}
    <div class="relative z-10 p-5 shrink-0 after:absolute after:left-5 after:right-5 after:top-0 after:h-px after:bg-gradient-to-r after:from-secondary/60 after:via-clay after:to-transparent">
      <a
        href={p('/contact')}
        class="group/cta relative flex items-center justify-center gap-2 px-4 py-3.5 rounded-full bg-secondary text-secondary-foreground font-semibold text-[15px] shadow-[0_10px_28px_-10px_hsl(var(--secondary)/.7)] hover:translate-y-[-1px] hover:shadow-[0_16px_34px_-10px_hsl(var(--secondary)/.8)] transition overflow-hidden"
      >
        {/* subtle sheen sweep on hover */}
        <span class="pointer-events-none absolute inset-0 -translate-x-full group-hover/cta:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/25 to-transparent" aria-hidden="true"></span>
        {t('nav.cta', lang)}
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="rtl-flip"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
      </a>
    </div>
  </aside>
</div>

<script is:inline>
  // Sticky / solid nav toggle. `is:inline` (not a bundled module) so it runs
  // during parse instead of after the deferred module graph loads — this is
  // what closes the white-text-on-light flash when the page loads already
  // scrolled (e.g. deep-linking to /#services from another page's nav).
  (function () {
    const nav = document.getElementById('nav');
    if (!nav || nav.dataset.solid === 'true') return;
    const scrim = nav.querySelector('[data-nav-scrim]');
    const apply = () => {
      const scrolled = window.scrollY > 40;
      nav.classList.toggle('bg-background/95', scrolled);
      nav.classList.toggle('backdrop-blur', scrolled);
      nav.classList.toggle('shadow-sm', scrolled);
      nav.classList.toggle('text-foreground', scrolled);
      nav.classList.toggle('text-white', !scrolled);
      if (scrim) scrim.style.opacity = scrolled ? '0' : '1';
    };
    window.addEventListener('scroll', apply, { passive: true });
    // Hash deep-links scroll AFTER parse, so re-apply on the events that fire
    // once the browser has jumped to the anchor. pageshow covers bfcache
    // restores (back/forward) where scroll position is recreated.
    window.addEventListener('load', apply);
    window.addEventListener('hashchange', apply);
    window.addEventListener('pageshow', apply);
    document.addEventListener('DOMContentLoaded', apply);
    apply();
  })();
</script>

<script is:inline>
  // Mobile drawer toggle. `is:inline` + PLAIN JS (no TypeScript) so the handler
  // is attached during parse — a deferred module left a brief window where the
  // first hamburger tap after load did nothing. Keep this block TS-free: an
  // is:inline script is emitted verbatim, so any TS syntax is a parse error
  // that kills it (this regressed the drawer once).
  (function () {
    var drawer = document.querySelector('[data-mobile-nav]');
    var trigger = document.querySelector('[data-mobile-nav-trigger]');
    var closeBtn = document.querySelector('[data-mobile-nav-close]');
    var backdrop = document.querySelector('[data-mobile-nav-backdrop]');
    var panel = document.querySelector('[data-mobile-nav-panel]');
    if (!drawer || !trigger || !closeBtn || !backdrop || !panel) return;
    var lastFocused = null;
    var isOpen = function () { return drawer.getAttribute('aria-hidden') === 'false'; };
    var open = function () {
      lastFocused = document.activeElement;
      drawer.style.pointerEvents = 'auto';
      drawer.setAttribute('aria-hidden', 'false');
      trigger.setAttribute('aria-expanded', 'true');
      backdrop.style.opacity = '1';
      panel.style.transform = 'translateX(0)';
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    };
    var close = function () {
      drawer.style.pointerEvents = 'none';
      drawer.setAttribute('aria-hidden', 'true');
      trigger.setAttribute('aria-expanded', 'false');
      backdrop.style.opacity = '0';
      panel.style.transform = 'translateX(100%)';
      document.body.style.overflow = '';
      if (lastFocused && lastFocused.focus) lastFocused.focus();
    };
    trigger.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    document.addEventListener('keydown', function (e) {
      if (!isOpen()) return;
      if (e.key === 'Escape') { close(); return; }
      // Focus trap: keep Tab within the panel while the dialog is open.
      if (e.key === 'Tab') {
        var f = panel.querySelectorAll('a[href],button:not([disabled])');
        if (!f.length) return;
        var first = f[0], last = f[f.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    });
    // Close when any link inside is tapped (mobile UX nicety).
    drawer.querySelectorAll('a[href]').forEach(function (a) { a.addEventListener('click', close); });
  })();
</script>
