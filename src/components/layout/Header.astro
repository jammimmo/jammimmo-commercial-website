---
import BrandMark from './BrandMark.astro';
import LanguageSwitcher from './LanguageSwitcher.tsx';
import { t, type Lang, localizedPath } from '@/lib/i18n';

interface Props {
  lang: Lang;
  /** When true, the nav stays opaque from the top (e.g. on /biens pages). */
  solid?: boolean;
}
const { lang, solid = false } = Astro.props;
const p = (path: string) => localizedPath(path, lang);

const navLinks: Array<{ href: string; key: string }> = [
  { href: p('/biens'),                key: 'nav.listings' },
  { href: `${p('/')}#services`,       key: 'nav.services' },
  { href: `${p('/')}#pourquoi`,       key: 'nav.why' },
  { href: `${p('/')}#process`,        key: 'nav.process' },
  { href: p('/contact'),              key: 'nav.contact' },
];
---

<nav
  id="nav"
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    solid ? 'bg-background/95 backdrop-blur shadow-sm text-foreground' : 'text-white',
  ]}
  data-solid={solid}
>
  <div class="container flex items-center justify-between h-[78px]">
    <a href={p('/')} class="flex items-center gap-3 font-extrabold tracking-wide text-[17px]">
      <BrandMark size={40} />
      <span class="leading-none">
        <span class="block">JAMM IMMOBILIER</span>
        <small class="block font-medium text-[10px] opacity-70 mt-1 tracking-[0.12em] uppercase">
          {t('site.tagline', lang)}
        </small>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-7 text-[14.5px] font-medium">
      {navLinks.map((l) => (
        <a href={l.href} class="relative py-1.5 hover:opacity-80">{t(l.key, lang)}</a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <LanguageSwitcher client:idle lang={lang} pathname={Astro.url.pathname} />
      <a
        href={p('/contact')}
        class="hidden sm:inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-secondary text-secondary-foreground font-semibold text-sm shadow-[0_6px_22px_-6px_hsl(var(--secondary)/.5)] hover:translate-y-[-1px] transition-transform"
      >
        {t('nav.cta', lang)}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="hidden sm:block">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>

      <!-- Mobile menu trigger — visible <md -->
      <button
        type="button"
        class="md:hidden w-10 h-10 grid place-items-center rounded-full bg-white/10 hover:bg-white/20 text-current transition"
        aria-label={t('nav.openMenu', lang)}
        aria-controls="mobile-nav"
        aria-expanded="false"
        data-mobile-nav-trigger
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile drawer — hidden below md and behind a JS-toggled class. -->
<div
  id="mobile-nav"
  class="md:hidden fixed inset-0 z-[60] pointer-events-none"
  data-mobile-nav
  aria-hidden="true"
>
  <div class="absolute inset-0 bg-black/55 opacity-0 transition-opacity duration-300" data-mobile-nav-backdrop></div>
  <aside
    role="dialog"
    aria-modal="true"
    aria-label={t('nav.openMenu', lang)}
    class="absolute top-0 right-0 bottom-0 w-[min(86vw,360px)] bg-card text-foreground shadow-2xl translate-x-full transition-transform duration-300 flex flex-col"
    data-mobile-nav-panel
  >
    <div class="flex items-center justify-between px-5 h-[78px] border-b border-clay">
      <span class="font-extrabold tracking-wide text-[15px]">JAMM IMMOBILIER</span>
      <button
        type="button"
        class="w-10 h-10 grid place-items-center rounded-full bg-muted hover:bg-clay transition"
        aria-label={t('nav.closeMenu', lang)}
        data-mobile-nav-close
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
    <ul class="flex-1 flex flex-col gap-1 p-5 text-[16px] font-medium overflow-y-auto">
      {navLinks.map((l) => (
        <li>
          <a href={l.href} class="block px-4 py-3 rounded-xl hover:bg-accent hover:text-accent-foreground transition">
            {t(l.key, lang)}
          </a>
        </li>
      ))}
    </ul>
    <div class="p-5 border-t border-clay">
      <a
        href={p('/contact')}
        class="flex items-center justify-center gap-2 px-4 py-3 rounded-full bg-secondary text-secondary-foreground font-semibold text-sm shadow-md"
      >
        {t('nav.cta', lang)}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
      </a>
    </div>
  </aside>
</div>

<script>
  // Sticky / solid nav toggle on scroll (unchanged behaviour).
  const nav = document.getElementById('nav');
  if (nav && nav.dataset.solid !== 'true') {
    const apply = () => {
      const scrolled = window.scrollY > 40;
      nav.classList.toggle('bg-background/95', scrolled);
      nav.classList.toggle('backdrop-blur', scrolled);
      nav.classList.toggle('shadow-sm', scrolled);
      nav.classList.toggle('text-foreground', scrolled);
      nav.classList.toggle('text-white', !scrolled);
    };
    window.addEventListener('scroll', apply, { passive: true });
    apply();
  }

  // Mobile drawer toggle. Pure DOM toggling — no framework needed; the
  // drawer markup is always present, JS just flips visibility classes.
  const drawer = document.querySelector<HTMLDivElement>('[data-mobile-nav]');
  const trigger = document.querySelector<HTMLButtonElement>('[data-mobile-nav-trigger]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-mobile-nav-close]');
  const backdrop = document.querySelector<HTMLDivElement>('[data-mobile-nav-backdrop]');
  const panel = document.querySelector<HTMLElement>('[data-mobile-nav-panel]');
  if (drawer && trigger && closeBtn && backdrop && panel) {
    let lastFocused: HTMLElement | null = null;
    const open = () => {
      lastFocused = document.activeElement as HTMLElement | null;
      drawer.style.pointerEvents = 'auto';
      drawer.setAttribute('aria-hidden', 'false');
      trigger.setAttribute('aria-expanded', 'true');
      backdrop.style.opacity = '1';
      panel.style.transform = 'translateX(0)';
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    };
    const close = () => {
      drawer.style.pointerEvents = 'none';
      drawer.setAttribute('aria-hidden', 'true');
      trigger.setAttribute('aria-expanded', 'false');
      backdrop.style.opacity = '0';
      panel.style.transform = 'translateX(100%)';
      document.body.style.overflow = '';
      lastFocused?.focus();
    };
    trigger.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') close();
    });
    // Close drawer when any link inside is clicked (mobile UX nicety).
    drawer.querySelectorAll('a[href]').forEach((a) => a.addEventListener('click', close));
  }
</script>
