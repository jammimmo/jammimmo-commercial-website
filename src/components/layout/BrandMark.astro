---
/**
 * Logo Jamm Immobilier — orb orange + clés blanches, tiré de l'identité.
 * SVG inline pour éviter une requête séparée et garder le mark crisp à toutes tailles.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 42, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 42 42"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class={className}
>
  <defs>
    <radialGradient id={`orb-${size}`} cx="38%" cy="35%" r="62%">
      <stop offset="0%" stop-color="#FFD080" />
      <stop offset="55%" stop-color="#F08826" />
      <stop offset="100%" stop-color="#C95A08" />
    </radialGradient>
  </defs>
  <circle cx="27" cy="16" r="13" fill={`url(#orb-${size})`} opacity=".95" />
  <g transform="rotate(-38 17 26)" opacity=".95">
    <rect x="15.5" y="11" width="3" height="14" rx="1.5" fill="white" />
    <circle cx="17" cy="10" r="4.5" stroke="white" stroke-width="2.5" fill="none" />
    <circle cx="17" cy="10" r="1.8" fill="white" />
    <rect x="18.5" y="19" width="4" height="2" rx="1" fill="white" />
    <rect x="18.5" y="23" width="3" height="2" rx="1" fill="white" />
  </g>
  <g transform="rotate(-52 14 28)" opacity=".75">
    <rect x="12.5" y="13" width="2.5" height="11" rx="1.25" fill="white" />
    <circle cx="13.75" cy="12" r="3.5" stroke="white" stroke-width="2" fill="none" />
    <circle cx="13.75" cy="12" r="1.4" fill="white" />
    <rect x="15" y="20" width="3" height="1.8" rx=".9" fill="white" />
    <rect x="15" y="23" width="2.2" height="1.8" rx=".9" fill="white" />
  </g>
</svg>
