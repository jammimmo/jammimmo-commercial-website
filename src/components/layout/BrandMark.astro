---
/**
 * Logo Jamm Immobilier — ICÔNE OFFICIELLE (orbe orange + clés) issue du kit
 * presse validé (`JAMM_IMMO_PRESS_KIT_FIDELE_2026` → icône exacte transparente),
 * et NON plus une recréation SVG approximative.
 *
 * PNG transparent → lisible aussi bien sur fond clair (nav solide) que sombre
 * (hero, footer). Décoratif : le wordmark texte « JAMM IMMOBILIER » accompagne
 * l'icône dans les en-têtes → `alt=""` + `aria-hidden`.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 42, class: className } = Astro.props;
---

<img
  src="/brand/jamm-icon.png"
  width={size}
  height={size}
  alt=""
  aria-hidden="true"
  decoding="async"
  loading="eager"
  class={className}
  style={`width:${size}px;height:${size}px`}
/>
