---
/**
 * Bouton flottant WhatsApp persistant — canal de contact dominant à Dakar.
 * Issu de l'audit UX mobile (Vague 2) : WhatsApp n'était joignable que depuis la
 * fiche bien. Ce FAB le rend disponible sur tout le site.
 *
 * Position : bas-GAUCHE, pour ne JAMAIS chevaucher le bouton « remonter en haut »
 * de la landing (bas-droite) ni la pastille « Carte » de /biens (bas-centre).
 * Désactivable par page (`hideWhatsappFab` sur BaseLayout) — ex. la fiche bien a
 * déjà sa barre CTA collante avec WhatsApp.
 */
import { t, type Lang } from '@/lib/i18n';
import { SITE } from '@/lib/site-config';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<a
  href={SITE.whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  data-track="whatsapp.fab.tapped"
  aria-label={t('whatsapp.fab.aria', lang)}
  class="fixed bottom-5 left-5 sm:bottom-6 sm:left-6 z-40 w-14 h-14 grid place-items-center rounded-full bg-[#25D366] text-white shadow-[0_12px_30px_-6px_rgba(37,211,102,0.6)] ring-1 ring-black/10 hover:brightness-110 hover:-translate-y-0.5 transition"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M17.47 14.38c-.29-.15-1.7-.84-1.96-.93-.26-.1-.45-.15-.64.14-.19.29-.74.93-.9 1.12-.17.19-.33.21-.62.07-.29-.15-1.22-.45-2.33-1.43-.86-.77-1.44-1.72-1.61-2.01-.17-.29-.02-.45.13-.59.13-.13.29-.34.43-.51.15-.17.19-.29.29-.48.1-.19.05-.36-.02-.51-.07-.15-.64-1.56-.89-2.13-.23-.55-.47-.48-.64-.49l-.55-.01c-.19 0-.5.07-.76.36-.26.29-1 .98-1 2.38 0 1.4 1.02 2.76 1.17 2.95.14.19 2.01 3.08 4.88 4.32.68.29 1.21.47 1.63.6.68.22 1.31.19 1.8.12.55-.08 1.7-.69 1.94-1.37.24-.67.24-1.25.17-1.37-.07-.12-.26-.19-.55-.34M12.04 21.5h-.01a9.45 9.45 0 0 1-4.81-1.32l-.35-.2-3.58.94.95-3.49-.23-.36a9.43 9.43 0 0 1-1.45-5.03c0-5.22 4.25-9.47 9.48-9.47 2.53 0 4.91.99 6.7 2.78a9.42 9.42 0 0 1 2.77 6.7c0 5.22-4.25 9.47-9.47 9.47m8.06-17.53A11.36 11.36 0 0 0 12.04.5C5.78.5.69 5.59.69 11.85c0 2 .52 3.95 1.51 5.67L.6 23.5l6.12-1.6a11.32 11.32 0 0 0 5.42 1.38h.01c6.26 0 11.35-5.09 11.35-11.35 0-3.03-1.18-5.88-3.32-8.02" />
  </svg>
</a>
