---
/**
 * PageProgress — navigation de lecture pour les pages longues (landing).
 *
 * Réunit trois patterns classiques en un seul composant SANS hydratation
 * (tout en `is:inline`, plain-JS — un script `is:inline` est émis verbatim,
 * donc AUCUNE syntaxe TS ici sous peine de casser le script, cf. Header.astro) :
 *
 *  1. **Barre de progression de lecture** (scroll progress bar) — un fin trait
 *     en haut qui se remplit selon le % de page scrollé.
 *  2. **Sommaire interactif au scroll** (scrollspy / « section dots ») — une
 *     colonne de pastilles à droite ; la section courante est surlignée en
 *     temps réel via IntersectionObserver, et chaque pastille saute à sa
 *     section (scroll fluide, avec décalage pour la nav fixe de 78px).
 *  3. **Bouton « remonter en haut »** (back-to-top / FAB) — apparaît après un
 *     défilement, ramène en haut en douceur.
 *
 * Accessibilité : `<nav aria-label>`, pastilles = liens avec `aria-current` sur
 * la section active, bouton avec `aria-label`. La barre est décorative
 * (`aria-hidden`). Respecte `prefers-reduced-motion` (scroll instantané).
 *
 * 100 % statique côté runtime (aucune dépendance données/secret) — réutilisable
 * sur n'importe quelle page longue en lui passant `sections`.
 */
import { t, type Lang } from '@/lib/i18n';

interface Section {
  id: string;
  labelKey: string;
}
interface Props {
  lang: Lang;
  /** Sections à lister dans le sommaire (par défaut : la landing page). */
  sections?: Section[];
}

const { lang, sections } = Astro.props;

// Défaut = sections ancrées de la landing page (ordre de scroll).
const items: Section[] = sections ?? [
  { id: 'proprietes', labelKey: 'nav.listings' },
  { id: 'services', labelKey: 'nav.services' },
  { id: 'pourquoi', labelKey: 'nav.why' },
  { id: 'process', labelKey: 'nav.process' },
  { id: 'faq', labelKey: 'nav.faq' },
  { id: 'contact', labelKey: 'nav.contact' },
];
---

{/* 1. Barre de progression de lecture — fixée tout en haut, au-dessus de la nav. */}
<div
  data-page-progress
  class="fixed top-0 left-0 z-[60] h-[3px] w-0 bg-secondary origin-left transition-[width] duration-150 ease-out pointer-events-none"
  aria-hidden="true"
>
</div>

{/* 2. Sommaire interactif (scrollspy / section dots) — colonne à droite, centrée. */}
<nav
  data-section-nav
  aria-label={t('nav.onThisPage', lang)}
  class="fixed right-3 sm:right-5 top-1/2 -translate-y-1/2 z-40 flex flex-col items-center gap-4 py-1 opacity-0 translate-x-2 pointer-events-none transition-all duration-500 ease-out"
>
  {/* Timeline verticale — transparente, relie les pastilles (derrière elles). */}
  <span
    class="absolute top-1.5 bottom-1.5 left-1/2 -translate-x-1/2 w-px bg-foreground/15"
    aria-hidden="true"
  >
  </span>
  {items.map((s) => (
    <a
      href={`#${s.id}`}
      data-spy-link={s.id}
      aria-label={t(s.labelKey, lang)}
      class="group/spy relative flex items-center justify-center"
    >
      {/* Libellé : flotte à GAUCHE (absolu). Au survol (desktop) + actif (JS). */}
      <span
        data-spy-label
        class="pointer-events-none absolute right-full mr-3 rounded-full bg-card text-foreground border border-clay shadow-sm px-2.5 py-1 text-[11px] font-semibold whitespace-nowrap opacity-0 translate-x-1 transition-all duration-200 group-hover/spy:opacity-100 group-hover/spy:translate-x-0"
      >
        {t(s.labelKey, lang)}
      </span>
      {/* Pastille (au-dessus de la ligne). */}
      <span
        data-spy-dot
        class="relative w-2.5 h-2.5 rounded-full bg-foreground/30 transition-all duration-200 group-hover/spy:bg-secondary"
      >
      </span>
    </a>
  ))}
</nav>

{/* 3. Bouton « remonter en haut » (back-to-top / FAB). */}
<button
  type="button"
  data-back-to-top
  aria-label={t('nav.backToTop', lang)}
  class="fixed bottom-8 right-6 sm:bottom-10 sm:right-8 z-40 w-12 h-12 grid place-items-center rounded-full bg-primary text-primary-foreground shadow-lg ring-1 ring-black/5 opacity-0 translate-y-3 pointer-events-none transition-all duration-300 hover:bg-secondary hover:text-secondary-foreground hover:-translate-y-0.5"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 19V5M5 12l7-7 7 7" />
  </svg>
</button>

<script is:inline>
  // Plain JS only (is:inline = emitted verbatim; any TS would be a parse error
  // that kills the whole block — same constraint as the mobile drawer script).
  (function () {
    // Différé au DOM prêt : ce script is:inline est émis EN HAUT de page, donc
    // les <section> ciblées n'existent pas encore au parse → on attend que le
    // DOM soit complet pour résoudre les sections du scrollspy.
    function init() {
    var bar = document.querySelector('[data-page-progress]');
    var fab = document.querySelector('[data-back-to-top]');
    var nav = document.querySelector('[data-section-nav]');
    var links = nav ? Array.prototype.slice.call(nav.querySelectorAll('[data-spy-link]')) : [];
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var NAV_OFFSET = 90; // hauteur de la nav fixe (78px) + petite marge.

    // Sections cibles (ordre du DOM).
    var targets = links
      .map(function (a) {
        var id = a.getAttribute('data-spy-link');
        return { id: id, el: document.getElementById(id) };
      })
      .filter(function (s) { return s.el; });

    // ---- 2b. Surligne la pastille + libellé de la section donnée ----
    // Styles INLINE (robustes : indépendants des classes Tailwind générées).
    function setActive(id) {
      links.forEach(function (a) {
        var on = a.getAttribute('data-spy-link') === id;
        var dot = a.querySelector('[data-spy-dot]');
        var label = a.querySelector('[data-spy-label]');
        if (on) {
          a.setAttribute('aria-current', 'true');
          if (dot) { dot.style.backgroundColor = 'hsl(var(--secondary))'; dot.style.transform = 'scale(1.4)'; }
          if (label) { label.style.opacity = '1'; label.style.transform = 'translateX(0)'; }
        } else {
          a.removeAttribute('aria-current');
          if (dot) { dot.style.backgroundColor = ''; dot.style.transform = ''; }
          if (label) { label.style.opacity = ''; label.style.transform = ''; }
        }
      });
    }

    // Section courante = la DERNIÈRE dont le haut a passé la ligne sous la nav.
    // Déterministe (toujours exactement une active), donc le libellé s'affiche
    // dynamiquement dès qu'on entre dans la section correspondante.
    function updateActive() {
      if (!targets.length) return;
      var probe = window.scrollY + NAV_OFFSET + 40;
      var current = targets[0].id;
      for (var i = 0; i < targets.length; i++) {
        if (targets[i].el.getBoundingClientRect().top + window.scrollY <= probe) current = targets[i].id;
      }
      setActive(current);
    }

    // ---- 1. Barre de progression + 2a. visibilité FAB/sommaire + 2b. section active ----
    function onScroll() {
      var doc = document.documentElement;
      var scrollable = doc.scrollHeight - window.innerHeight;
      var pct = scrollable > 0 ? Math.min(1, Math.max(0, window.scrollY / scrollable)) : 0;
      if (bar) bar.style.width = (pct * 100).toFixed(2) + '%';
      if (fab) {
        var show = window.scrollY > 600;
        fab.style.opacity = show ? '1' : '0';
        fab.style.transform = show ? 'translateY(0)' : 'translateY(0.75rem)';
        fab.style.pointerEvents = show ? 'auto' : 'none';
      }
      // Le sommaire (timeline) apparaît en fondu après le hero, puis reste.
      if (nav) {
        var showNav = window.scrollY > 350;
        nav.style.opacity = showNav ? '1' : '0';
        // Conserve le centrage vertical (translateY(-50%)) imposé par la classe.
        nav.style.transform = 'translateY(-50%) ' + (showNav ? 'translateX(0)' : 'translateX(0.5rem)');
        nav.style.pointerEvents = showNav ? 'auto' : 'none';
      }
      updateActive();
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    onScroll();

    // ---- 3. Remonter en haut ----
    if (fab) {
      fab.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
      });
    }

    // Clic pastille → scroll fluide (décalage nav) + activation immédiate.
    links.forEach(function (a) {
      a.addEventListener('click', function (e) {
        var id = a.getAttribute('data-spy-link');
        var el = document.getElementById(id);
        if (!el) return; // laisse le comportement par défaut si la section manque
        e.preventDefault();
        var y = el.getBoundingClientRect().top + window.scrollY - NAV_OFFSET;
        window.scrollTo({ top: y, behavior: reduce ? 'auto' : 'smooth' });
        setActive(id);
      });
    });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
