---
import type { Quartier } from '@/lib/quartiers';
import { t, type Lang, localizedPath } from '@/lib/i18n';
import { ArrowRight, MapPin } from 'lucide-react';

interface Props {
  /** Quartiers with their current available-listing counts. */
  items: Array<{ quartier: Quartier; count: number }>;
  lang: Lang;
}
const { items, lang } = Astro.props;
const p = (path: string) => localizedPath(path, lang);
const tpl = (key: string, vars: Record<string, string>) =>
  Object.entries(vars).reduce((s, [k, v]) => s.replaceAll(`{${k}}`, v), t(key, lang));
---

<section class="bg-card border-b border-clay py-12 sm:py-16">
  <div class="container max-w-3xl">
    <p class="text-[11px] uppercase tracking-[0.18em] font-semibold text-secondary-strong mb-3">
      {t('geo.hub.eyebrow', lang)}
    </p>
    <h1 class="font-serif font-light text-[clamp(34px,5vw,60px)] leading-tight tracking-tight">
      {t('geo.hub.title', lang)}
    </h1>
    <p class="mt-4 text-muted-foreground text-[16.5px] leading-relaxed">{t('geo.hub.subtitle', lang)}</p>
  </div>
</section>

<section class="property-detail-bg py-12 sm:py-16">
  <div class="container">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map(({ quartier: q, count }) => (
        <a
          href={p(`/immobilier/${q.slug}`)}
          class="group flex flex-col justify-between rounded-2xl bg-card border border-clay p-6 hover:border-primary hover:shadow-[0_30px_60px_-40px_hsl(var(--ink)/.35)] hover:translate-y-[-3px] transition-all"
        >
          <div>
            <div class="flex items-center gap-2 text-secondary-strong">
              <MapPin className="w-4 h-4" />
              <span class="text-[11px] uppercase tracking-[0.14em] font-semibold">{q.city}</span>
            </div>
            <h2 class="font-serif text-[24px] tracking-tight mt-2 group-hover:text-primary transition">{q.name}</h2>
            <p class="mt-2 text-[14px] text-muted-foreground leading-relaxed line-clamp-3">
              {q.intro[lang === 'en' ? 'en' : 'fr']}
            </p>
          </div>
          <div class="mt-5 flex items-center justify-between">
            <span class="text-[13px] font-semibold text-foreground/70">
              {count > 0 ? tpl('geo.hub.linkLabel', { count: String(count) }) : ''}
            </span>
            <span class="inline-flex items-center gap-1 text-[13px] font-semibold text-primary group-hover:gap-2 transition-all">
              Voir <ArrowRight className="w-4 h-4" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
