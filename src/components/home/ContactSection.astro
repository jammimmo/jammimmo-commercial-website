---
import ContactForm from '@/components/forms/ContactForm.tsx';
import PropertyMap from '@/components/property/PropertyMap.tsx';
import { t, type Lang } from '@/lib/i18n';
import { SITE, TEL_URI, MAILTO_URI, MAPS_DIRECTIONS_URI } from '@/lib/site-config';
import { MapPin, Phone, Mail, Navigation } from 'lucide-react';
interface Props { lang: Lang }
const { lang } = Astro.props;
const agencyGps = `${SITE.geo.lat}, ${SITE.geo.lng}`;
---

<section id="contact" class="py-20 lg:py-[130px] text-white relative overflow-hidden" style="background: radial-gradient(circle at 90% 10%, rgba(240,136,38,.2), transparent 40%), linear-gradient(180deg, hsl(var(--primary)) 0%, hsl(var(--primary) / 0.85) 100%);">
  <div class="absolute left-[-10%] bottom-[-30%] w-[500px] h-[500px] rounded-full pointer-events-none" style="background:radial-gradient(circle, rgba(240,136,38,.35), transparent 70%);filter:blur(40px);"></div>
  <div class="container relative z-[2]">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div>
        <div class="reveal inline-flex items-center gap-2 text-[12px] font-semibold tracking-wider uppercase text-[hsl(var(--secondary)/.85)] before:content-[''] before:w-6 before:h-px before:bg-[hsl(var(--secondary)/.85)]">
          {t('contact.tag', lang)}
        </div>
        <h2 class="reveal d1 font-serif font-light text-[clamp(36px,4.8vw,68px)] leading-none tracking-tight mt-3 max-w-[14ch]">
          <em class="italic text-[hsl(var(--secondary)/.95)] font-normal not-italic">{t('contact.title.line1', lang)}</em><br />
          {t('contact.title.line2', lang)}
        </h2>
        <p class="reveal d1 text-white/75 max-w-[46ch] mt-7 mb-9 leading-relaxed text-[16.5px]">{t('contact.lead', lang)}</p>

        <div class="flex flex-col gap-4">
          <div class="reveal d1 flex gap-4 items-start p-5 rounded-2xl bg-white/8 border border-white/15">
            <div class="w-10 h-10 rounded-xl bg-secondary/25 text-[hsl(var(--secondary)/.95)] grid place-items-center shrink-0">
              <MapPin className="w-5 h-5" strokeWidth={1.7} />
            </div>
            <div>
              <b class="block text-[11px] tracking-wider uppercase text-white/60 font-semibold mb-1">{t('contact.info.agency', lang)}</b>
              <span class="text-[15px]">{SITE.address.display}</span>
              <a
                href={MAPS_DIRECTIONS_URI}
                target="_blank"
                rel="noopener noreferrer"
                data-track="directions.tapped"
                data-track-prop-source="contact"
                class="mt-2 inline-flex items-center gap-1.5 text-[13px] font-semibold text-[hsl(var(--secondary)/.95)] hover:text-secondary"
              >
                <Navigation className="w-3.5 h-3.5" />{t('contact.info.directions', lang)}
              </a>
            </div>
          </div>
          <div class="reveal d2 flex gap-4 items-start p-5 rounded-2xl bg-white/8 border border-white/15">
            <div class="w-10 h-10 rounded-xl bg-secondary/25 text-[hsl(var(--secondary)/.95)] grid place-items-center shrink-0">
              <Phone className="w-5 h-5" strokeWidth={1.7} />
            </div>
            <div class="min-w-0">
              <b class="block text-[11px] tracking-wider uppercase text-white/60 font-semibold mb-1">{t('contact.info.phone', lang)}</b>
              <a href={TEL_URI} data-track="phone.tapped" data-track-prop-source="contact" class="text-[15px] hover:text-secondary">{SITE.phoneDisplay}</a>
              {/* WhatsApp = canal dominant à Dakar → bouton dédié bien visible, en plus de l'appel. */}
              <div class="flex flex-wrap gap-2 mt-3">
                <a
                  href={TEL_URI}
                  data-track="phone.call.tapped"
                  data-track-prop-source="contact"
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/15 border border-white/25 text-[13.5px] font-semibold hover:bg-white/25 transition"
                >
                  <Phone className="w-4 h-4" strokeWidth={2} />{t('property.detail.call', lang)}
                </a>
                <a
                  href={SITE.whatsappUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-track="whatsapp.tapped"
                  data-track-prop-source="contact"
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-[#25D366] text-white text-[13.5px] font-semibold shadow-sm hover:brightness-110 transition"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M17.47 14.38c-.29-.15-1.7-.84-1.96-.93-.26-.1-.45-.15-.64.14-.19.29-.74.93-.9 1.12-.17.19-.33.21-.62.07-.29-.15-1.22-.45-2.33-1.43-.86-.77-1.44-1.72-1.61-2.01-.17-.29-.02-.45.13-.59.13-.13.29-.34.43-.51.15-.17.19-.29.29-.48.1-.19.05-.36-.02-.51-.07-.15-.64-1.56-.89-2.13-.23-.55-.47-.48-.64-.49l-.55-.01c-.19 0-.5.07-.76.36-.26.29-1 .98-1 2.38 0 1.4 1.02 2.76 1.17 2.95.14.19 2.01 3.08 4.88 4.32.68.29 1.21.47 1.63.6.68.22 1.31.19 1.8.12.55-.08 1.7-.69 1.94-1.37.24-.67.24-1.25.17-1.37-.07-.12-.26-.19-.55-.34M12.04 21.5h-.01a9.45 9.45 0 0 1-4.81-1.32l-.35-.2-3.58.94.95-3.49-.23-.36a9.43 9.43 0 0 1-1.45-5.03c0-5.22 4.25-9.47 9.48-9.47 2.53 0 4.91.99 6.7 2.78a9.42 9.42 0 0 1 2.77 6.7c0 5.22-4.25 9.47-9.47 9.47m8.06-17.53A11.36 11.36 0 0 0 12.04.5C5.78.5.69 5.59.69 11.85c0 2 .52 3.95 1.51 5.67L.6 23.5l6.12-1.6a11.32 11.32 0 0 0 5.42 1.38h.01c6.26 0 11.35-5.09 11.35-11.35 0-3.03-1.18-5.88-3.32-8.02" />
                  </svg>
                  {t('property.detail.whatsapp', lang)}
                </a>
              </div>
            </div>
          </div>
          <div class="reveal d3 flex gap-4 items-start p-5 rounded-2xl bg-white/8 border border-white/15">
            <div class="w-10 h-10 rounded-xl bg-secondary/25 text-[hsl(var(--secondary)/.95)] grid place-items-center shrink-0">
              <Mail className="w-5 h-5" strokeWidth={1.7} />
            </div>
            <div>
              <b class="block text-[11px] tracking-wider uppercase text-white/60 font-semibold mb-1">{t('contact.info.email', lang)}</b>
              <a href={MAILTO_URI} class="text-[15px] hover:text-secondary">{SITE.email}</a>
            </div>
          </div>
        </div>

        {/* Agency location map — lazy (client:visible) so Leaflet only loads
            when the contact section scrolls into view. */}
        <div class="reveal d3 mt-5 h-[220px] rounded-2xl overflow-hidden border border-white/15">
          <PropertyMap
            client:visible
            gps={agencyGps}
            title={SITE.agencyName}
            className="w-full h-full block"
          />
        </div>
      </div>

      <div class="reveal d2">
        <ContactForm client:visible lang={lang} />
      </div>
    </div>
  </div>
</section>
