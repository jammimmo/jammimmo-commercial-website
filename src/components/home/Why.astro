---
import { t, type Lang } from '@/lib/i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;

const items = [
  { num: '01', key: 'why.1', delay: 'd1' as const },
  { num: '02', key: 'why.2', delay: 'd2' as const },
  { num: '03', key: 'why.3', delay: 'd3' as const },
  { num: '04', key: 'why.4', delay: 'd4' as const },
];
---

<section id="pourquoi" class="py-20 lg:py-[130px] bg-[hsl(var(--primary)/.96)] text-white relative overflow-hidden">
  <div class="absolute right-[-10%] top-[-20%] w-[560px] h-[560px] rounded-full pointer-events-none" style="background:radial-gradient(circle, rgba(240,136,38,.35), transparent 70%);filter:blur(40px);"></div>
  <div class="container relative z-[2]">
    <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_1fr] gap-20 items-start">
      <div>
        <div class="reveal inline-flex items-center gap-2 text-[12px] font-semibold tracking-wider uppercase text-[hsl(var(--secondary)/.85)] before:content-[''] before:w-6 before:h-px before:bg-[hsl(var(--secondary)/.85)]">
          {t('why.tag', lang)}
        </div>
        <h2 class="reveal d1 font-serif font-light text-[clamp(36px,4.8vw,68px)] leading-none tracking-tight mt-3 max-w-[14ch]">
          <span set:html={t('why.title', lang).replace(/(méthode|method)/i, '<em class="italic text-[hsl(var(--secondary)/.95)] font-normal">$1</em>')} />
        </h2>
        <ul class="flex flex-col gap-3.5 mt-6">
          {items.map((item, i) => (
            <li class={`reveal ${item.delay} flex gap-5 py-5 border-t border-white/12 ${i === items.length - 1 ? 'border-b' : ''}`}>
              <div class="font-serif text-[32px] font-light text-[hsl(var(--secondary)/.85)] min-w-[48px]">{item.num}</div>
              <div>
                <h3 class="m-0 mb-1.5 text-[18px] font-semibold">{t(`${item.key}.title`, lang)}</h3>
                <p class="m-0 text-white/70 leading-relaxed text-[14.5px] max-w-[48ch]">{t(`${item.key}.desc`, lang)}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="reveal d2 bg-white/8 border border-white/15 rounded-3xl p-7 backdrop-blur">
        <h3 class="font-serif font-normal text-[24px] tracking-tight m-0">{t('why.map.title', lang)}</h3>
        <div class="mt-5 aspect-square rounded-2xl overflow-hidden bg-gradient-to-b from-primary to-[hsl(var(--primary)/.4)] relative">
          <svg viewBox="0 0 400 300" class="absolute inset-0 w-full h-full" fill="none" stroke="rgba(255,255,255,.18)" stroke-width="1.2">
            <path d="M40 120 L80 80 L160 70 L240 60 L320 90 L360 130 L350 200 L280 230 L200 240 L160 220 L120 240 L80 220 L60 180 Z" />
            <path d="M120 150 L200 145 L240 160 L220 180 L160 175 Z" stroke="rgba(255,255,255,.1)" stroke-dasharray="3 3" />
          </svg>
          {[
            { left: '18%', top: '46%', name: 'Saint-Louis' },
            { left: '30%', top: '62%', name: 'Thiès' },
            { left: '24%', top: '70%', name: 'Dakar' },
            { left: '38%', top: '76%', name: 'Mbour / Saly' },
            { left: '62%', top: '78%', name: 'Kaolack' },
            { left: '80%', top: '86%', name: 'Ziguinchor' },
          ].map((d) => (
            <span
              class="absolute w-3.5 h-3.5 rounded-full bg-secondary -translate-x-1/2 -translate-y-1/2 shadow-[0_0_0_6px_rgba(240,136,38,.25)] cursor-pointer"
              style={`left:${d.left};top:${d.top}`}
              title={d.name}
            ></span>
          ))}
        </div>
        <div class="flex justify-between mt-5 text-[13px] text-white/70">
          <span><b class="text-white font-semibold">{t('why.map.meta.cities', lang)}</b></span>
          <span><b class="text-white font-semibold">{t('why.map.meta.props', lang)}</b></span>
        </div>
      </div>
    </div>
  </div>
</section>
