---
/**
 * « Guides » — home section featuring the editorial guides (they were only in
 * the footer/drawer; this surfaces them to every visitor). Shows up to 4 guides
 * for the active language (FR fallback) + a CTA to the full hub. Localized.
 */
import { getCollection } from 'astro:content';
import { type Lang, t, localizedPath } from '@/lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const all = await getCollection('guides');
const slugs = [...new Set(all.map((e) => e.slug.split('/')[0]))];
const guides = slugs
  .map((slug) => {
    const e = all.find((x) => x.slug === `${slug}/${lang}`) ?? all.find((x) => x.slug === `${slug}/fr`);
    return e ? { slug, data: e.data } : null;
  })
  .filter((g): g is { slug: string; data: (typeof all)[number]['data'] } => Boolean(g))
  .sort((a, b) => a.data.order - b.data.order || (a.data.date < b.data.date ? 1 : a.data.date > b.data.date ? -1 : 0))
  .slice(0, 4);
---

{guides.length > 0 && (
  <section id="guides" class="py-20 lg:py-[110px] bg-background">
    <div class="container">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12 reveal">
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-2 text-[12px] font-semibold tracking-wider uppercase text-secondary-strong">
            {t('guides.eyebrow', lang)}
          </div>
          <h2 class="font-serif font-light text-[clamp(32px,4.4vw,56px)] leading-tight tracking-tight mt-3">
            {t('guides.hubTitle', lang)}
          </h2>
          <p class="text-muted-foreground leading-relaxed mt-4">{t('guides.hubSubtitle', lang)}</p>
        </div>
        <a
          href={localizedPath('/guides', lang)}
          data-track="home.guides.all"
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:gap-2.5 transition-all shrink-0"
        >
          {t('guides.allGuides', lang)}
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="rtl-flip"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {guides.map((g, i) => (
          <a
            href={localizedPath(`/guides/${g.slug}`, lang)}
            data-track={`home.guides.card.${g.slug}`}
            class={`reveal ${i > 0 ? `d${Math.min(i, 3)}` : ''} group flex flex-col bg-card rounded-[22px] p-6 border border-clay hover:translate-y-[-6px] hover:shadow-[0_30px_60px_-30px_hsl(var(--ink)/.2)] hover:border-secondary/40 transition`}
          >
            <p class="text-[11px] uppercase tracking-wider font-semibold text-secondary-strong">{g.data.category}</p>
            <h3 class="font-serif text-[20px] leading-snug tracking-tight mt-2 mb-2 sm:min-h-[3.5rem]">{g.data.title}</h3>
            <p class="text-muted-foreground text-[13.5px] leading-relaxed flex-1 line-clamp-3">{g.data.description}</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary mt-4 group-hover:gap-2.5 transition-all">
              {t('guides.readGuide', lang)}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="rtl-flip"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
