---
import { t, type Lang } from '@/lib/i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;
---

<section class="py-24 sm:py-32 bg-card">
  <div class="container">
    <div class="flex flex-col lg:flex-row justify-between gap-8 mb-14">
      <div class="reveal">
        <div class="inline-flex items-center gap-2 text-[12px] font-semibold tracking-wider uppercase text-primary before:content-[''] before:w-6 before:h-px before:bg-primary">
          {t('testi.tag', lang)}
        </div>
        <h2 class="font-serif font-light text-[clamp(36px,4.8vw,68px)] leading-none tracking-tight mt-3 max-w-[14ch]">
          <span set:html={t('testi.title', lang).replace(/(fait confiance|trusted us|topptoo)/i, '<em class="italic text-primary font-normal">$1</em>')} />
        </h2>
      </div>
      <p class="reveal d1 text-muted-foreground leading-relaxed max-w-[420px] hidden md:block">{t('testi.subtitle', lang)}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {[1, 2, 3].map((n, i) => (
        <div class={`reveal ${i > 0 ? `d${i}` : ''} p-8 rounded-[22px] bg-background border border-clay flex flex-col gap-5`}>
          <span class="font-serif text-[60px] leading-[0.6] text-secondary italic">"</span>
          <blockquote class="m-0 font-serif font-light text-[21px] leading-snug tracking-tight">
            {t(`testi.${n}.quote`, lang)}
          </blockquote>
          <div class="flex items-center gap-3.5 mt-auto">
            <div class="w-11 h-11 rounded-full bg-primary text-primary-foreground grid place-items-center font-bold text-[15px] tracking-wider">
              {t(`testi.${n}.name`, lang).replace(/^([A-Z])\.\s*([A-Z])/, '$1$2')}
            </div>
            <div>
              <b class="block text-[14px]">{t(`testi.${n}.name`, lang)}</b>
              <span class="block text-[12px] text-muted-foreground mt-0.5">{t(`testi.${n}.role`, lang)}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
