---
/**
 * Partner / business-introducer landing page body ("Page partenaire", ticket 8).
 *
 * Twin of OwnerContent.astro for APPORTEURS D'AFFAIRES / PARTENAIRES (agencies,
 * brokers, individuals who bring a property or a client to Jamm Immobilier).
 *
 * STATIC marketing content only — no DB read, no Supabase, no new endpoint.
 * The primary CTA reuses the SAME convention as OwnerContent's "Gestion" link:
 * localizedPath('/contact?subject=partenariat', lang). It is a plain internal
 * link with NO data-track event (mirrors the Header's /contact CTA) — the
 * page-view is auto-tracked by BaseLayout, and conversion is captured by
 * `lead.form.submitted` on the /contact form itself. The `?subject=` param is
 * the established slug convention (cf. ?subject=gestion); it is inert today but
 * carries the partner intent if the form ever consumes it.
 *
 * Secondary phone / WhatsApp CTAs reuse the EXISTING allowlisted events
 * `phone.tapped` / `whatsapp.tapped` (see the AnalyticsEvent union in
 * src/lib/analytics.ts). No new event names are introduced. The `source` prop
 * is intentionally omitted: that field is an allowlist
 * ('header'|'detail'|'contact'|'drawer'|'sticky') and a partner-page value is
 * not part of it, so we leave the optional prop off rather than invent one.
 *
 * Design-system patterns are IMITATED (not imported) from the homepage
 * sections (Hero / Services / Process / Why / ContactSection) so the page
 * looks native; all copy is driven by the partner.* i18n keys.
 */
import { t, type Lang, localizedPath } from '@/lib/i18n';
import { SITE, TEL_URI } from '@/lib/site-config';
import { Wallet, ShieldCheck, LineChart, Network, MessageSquare, BadgeCheck, Phone } from 'lucide-react';

interface Props { lang: Lang }
const { lang } = Astro.props;
const p = (path: string) => localizedPath(path, lang);

// Established slug convention (cf. OwnerContent's ?subject=gestion).
const partnerCtaHref = p('/contact?subject=partenariat');

// Six partner value props — Services-card archetype, alternating icon tones.
const benefits = [
  { key: 'partner.benefit.1', icon: 'wallet',   tone: 'primary' },
  { key: 'partner.benefit.2', icon: 'shield',   tone: 'secondary' },
  { key: 'partner.benefit.3', icon: 'linechart', tone: 'primary' },
  { key: 'partner.benefit.4', icon: 'network',  tone: 'secondary' },
  { key: 'partner.benefit.5', icon: 'message',  tone: 'primary' },
  { key: 'partner.benefit.6', icon: 'badge',    tone: 'secondary' },
] as const;
---

{/* ─── Hero ─── lighter take on Hero.astro: brand indigo gradient, eyebrow
     pill + serif h1 + dual CTA. No parallax scene (this is a sub-page). */}
<header
  class="relative overflow-hidden text-white isolate"
  style="background: linear-gradient(160deg,#1f2a8e 0%, #2632A0 45%, #3845C2 100%);"
>
  {/* Subtle grid + sun-glow decor, no JS — purely cosmetic. */}
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: linear-gradient(rgba(255,255,255,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.05) 1px,transparent 1px); background-size:80px 80px; mask-image:linear-gradient(180deg, transparent, #000 30%, #000 90%, transparent); -webkit-mask-image:linear-gradient(180deg, transparent, #000 30%, #000 90%, transparent);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute right-[-8%] top-[-30%] w-[520px] h-[520px] rounded-full pointer-events-none max-w-[80vw] max-h-[80vw]"
    style="background:radial-gradient(circle at 38% 38%, rgba(245,165,82,.45), rgba(240,136,38,.2) 45%, transparent 72%);filter:blur(20px);"
    aria-hidden="true"
  ></div>

  <div class="container relative z-[2] pt-[120px] pb-[88px] md:pt-[150px] md:pb-[120px] max-w-[860px]">
    <span class="reveal inline-flex items-center gap-2.5 px-3.5 py-2 rounded-full bg-white/10 border border-white/25 text-[12.5px] font-medium tracking-[0.06em] backdrop-blur">
      <span class="w-2 h-2 rounded-full bg-secondary shadow-[0_0_0_4px_rgba(240,136,38,.25)]"></span>
      {t('partner.eyebrow', lang)}
    </span>

    <h1 class="reveal d1 font-serif font-light text-[clamp(40px,6vw,86px)] leading-[0.98] tracking-[-0.02em] mt-6 mb-6 [text-wrap:balance]">
      <span set:html={t('partner.title', lang).replace(/(rémunéré|rewarded|fey)/i, '<em class="italic text-[hsl(var(--secondary)/.9)] font-normal">$1</em>')} />
    </h1>

    <p class="reveal d2 text-[18px] leading-[1.55] max-w-[600px] opacity-85">{t('partner.subtitle', lang)}</p>

    <div class="reveal d3 flex flex-wrap gap-3.5 mt-9">
      <a
        href={partnerCtaHref}
        class="inline-flex items-center gap-2.5 px-[26px] py-4 rounded-full bg-secondary text-secondary-foreground font-semibold text-[15px] shadow-[0_10px_30px_-4px_rgba(240,136,38,.4)] hover:translate-y-[-2px] hover:shadow-[0_16px_36px_-4px_rgba(240,136,38,.5)] transition"
      >
        {t('partner.cta.primary', lang)}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
      </a>
      <a
        href={TEL_URI}
        data-track="phone.tapped"
        class="inline-flex items-center gap-2.5 px-[26px] py-4 rounded-full bg-white/10 border border-white/30 hover:bg-white/20 transition font-semibold text-[15px]"
      >
        <Phone className="w-[18px] h-[18px]" strokeWidth={2} />
        {t('partner.cta.call', lang)}
      </a>
    </div>
  </div>
</header>

{/* ─── Value props ─── Services-card archetype: 6 lucide-icon cards. */}
<section class="py-20 lg:py-[130px] bg-background">
  <div class="container">
    <div class="flex flex-col lg:flex-row justify-between gap-8 mb-14">
      <div class="reveal">
        <div class="inline-flex items-center gap-2 text-[12px] font-semibold tracking-wider uppercase text-primary before:content-[''] before:w-6 before:h-px before:bg-primary">
          {t('partner.benefits.tag', lang)}
        </div>
        <h2 class="font-serif font-light text-[clamp(36px,4.8vw,68px)] leading-none tracking-tight mt-3 max-w-[16ch]">
          <span set:html={t('partner.benefits.title', lang).replace(/(votre apport|what you bring|li nga indi)/i, '<em class="italic text-primary font-normal">$1</em>')} />
        </h2>
      </div>
      <p class="reveal d1 text-muted-foreground leading-relaxed max-w-[420px] hidden md:block">
        {t('partner.benefits.subtitle', lang)}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {benefits.map((b, i) => (
        <div class={`reveal ${i > 0 ? `d${Math.min(i, 3)}` : ''} bg-card rounded-[22px] p-7 border border-clay min-h-[260px] flex flex-col justify-between hover:translate-y-[-6px] hover:shadow-[0_30px_60px_-30px_hsl(var(--ink)/.2)] hover:border-transparent transition group relative overflow-hidden`}>
          <div>
            <div class={`w-14 h-14 rounded-2xl grid place-items-center ${b.tone === 'primary' ? 'bg-accent text-primary' : 'bg-secondary/15 text-secondary-strong'}`}>
              {b.icon === 'wallet' && <Wallet className="w-6 h-6" strokeWidth={1.6} />}
              {b.icon === 'shield' && <ShieldCheck className="w-6 h-6" strokeWidth={1.6} />}
              {b.icon === 'linechart' && <LineChart className="w-6 h-6" strokeWidth={1.6} />}
              {b.icon === 'network' && <Network className="w-6 h-6" strokeWidth={1.6} />}
              {b.icon === 'message' && <MessageSquare className="w-6 h-6" strokeWidth={1.6} />}
              {b.icon === 'badge' && <BadgeCheck className="w-6 h-6" strokeWidth={1.6} />}
            </div>
            <h3 class="font-serif font-normal text-[24px] tracking-tight mt-6 mb-2.5">{t(`${b.key}.title`, lang)}</h3>
            <p class="text-muted-foreground leading-relaxed text-[14.5px]">{t(`${b.key}.desc`, lang)}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

{/* ─── How it works ─── Process archetype: oversized ghost numerals + steps. */}
<section class="py-20 lg:py-[130px] bg-background relative">
  <div class="container">
    <div class="flex flex-col lg:flex-row justify-between gap-8 mb-14">
      <div class="reveal">
        <div class="inline-flex items-center gap-2 text-[12px] font-semibold tracking-wider uppercase text-primary before:content-[''] before:w-6 before:h-px before:bg-primary">
          {t('partner.steps.tag', lang)}
        </div>
        <h2 class="font-serif font-light text-[clamp(36px,4.8vw,68px)] leading-none tracking-tight mt-3 max-w-[14ch]">
          <span set:html={t('partner.steps.title', lang).replace(/(en quatre étapes|in four steps|ñeenti tönk)/i, '<em class="italic text-primary font-normal">$1</em>')} />
        </h2>
      </div>
      <p class="reveal d1 text-muted-foreground leading-relaxed max-w-[420px] hidden md:block">{t('partner.steps.subtitle', lang)}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-5 relative">
      {[1, 2, 3, 4].map((n, i) => (
        <div class={`reveal ${i > 0 ? `d${Math.min(i, 3)}` : ''} relative`}>
          <div class="font-serif text-[96px] font-light leading-[0.85] tracking-tighter text-primary opacity-20">
            {String(n).padStart(2, '0')}
          </div>
          <h3 class="font-serif text-[22px] mt-3.5 mb-2">{t(`partner.step.${n}.title`, lang)}</h3>
          <p class="text-muted-foreground text-[14.5px] leading-relaxed">{t(`partner.step.${n}.desc`, lang)}</p>
        </div>
      ))}
    </div>
  </div>
</section>

{/* ─── Final CTA ─── ContactSection's dark indigo + sun radial gradient,
     used here as a focused conversion closer (no embedded form — we point at
     the existing /contact?subject=partenariat page). */}
<section class="py-20 lg:py-[130px] text-white relative overflow-hidden" style="background: radial-gradient(circle at 90% 10%, rgba(240,136,38,.2), transparent 40%), linear-gradient(180deg, hsl(var(--primary)) 0%, hsl(var(--primary) / 0.85) 100%);">
  <div class="absolute left-[-10%] bottom-[-30%] w-[500px] h-[500px] rounded-full pointer-events-none" style="background:radial-gradient(circle, rgba(240,136,38,.35), transparent 70%);filter:blur(40px);" aria-hidden="true"></div>
  <div class="container relative z-[2] max-w-[760px] text-center">
    <div class="reveal inline-flex items-center gap-2 text-[12px] font-semibold tracking-wider uppercase text-[hsl(var(--secondary)/.85)] before:content-[''] before:w-6 before:h-px before:bg-[hsl(var(--secondary)/.85)] after:content-[''] after:w-6 after:h-px after:bg-[hsl(var(--secondary)/.85)]">
      {t('partner.final.tag', lang)}
    </div>
    <h2 class="reveal d1 font-serif font-light text-[clamp(34px,4.6vw,62px)] leading-tight tracking-tight mt-4 [text-wrap:balance]">
      <span set:html={t('partner.final.title', lang).replace(/(un message suffit|one message is enough|benn bataaxal doy na)/i, '<em class="italic text-[hsl(var(--secondary)/.95)] font-normal">$1</em>')} />
    </h2>
    <p class="reveal d1 text-white/75 max-w-[52ch] mx-auto mt-6 mb-9 leading-relaxed text-[16.5px]">{t('partner.final.lead', lang)}</p>

    <div class="reveal d2 flex flex-wrap justify-center gap-3.5">
      <a
        href={partnerCtaHref}
        class="inline-flex items-center gap-2.5 px-[26px] py-4 rounded-full bg-secondary text-secondary-foreground font-semibold text-[15px] shadow-[0_10px_30px_-4px_rgba(240,136,38,.4)] hover:translate-y-[-2px] hover:shadow-[0_16px_36px_-4px_rgba(240,136,38,.5)] transition"
      >
        {t('partner.cta.primary', lang)}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
      </a>
      <a
        href={SITE.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-track="whatsapp.tapped"
        class="inline-flex items-center gap-2.5 px-[26px] py-4 rounded-full bg-white/10 border border-white/30 hover:bg-white/20 transition font-semibold text-[15px]"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.3A10 10 0 1 0 12 2zm5.6 14.2c-.2.6-1.3 1.2-1.8 1.3-.5.1-1.1.1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.7-4-4.8-4.2-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.3-.3.6-.4.8-.4h.6c.2 0 .4 0 .6.5.2.5.7 1.7.7 1.8.1.1.1.3 0 .5l-.3.4-.4.5c-.1.1-.3.3-.1.6.2.3.8 1.3 1.8 2.1 1.2 1.1 2.2 1.4 2.5 1.5.3.1.5.1.7-.1.2-.2.7-.9 1-1.2.2-.3.4-.2.7-.1.3.1 1.7.8 2 1 .3.1.5.2.6.3.1.2.1.7-.1 1.4z"/></svg>
        WhatsApp
      </a>
    </div>
    <a href={TEL_URI} data-track="phone.tapped" class="reveal d3 mt-7 inline-block font-serif text-[22px] tracking-tight text-white hover:text-secondary transition">{SITE.phoneDisplay}</a>
  </div>
</section>
