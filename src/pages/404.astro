---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLang, t, localizedPath } from '@/lib/i18n';

export const prerender = true;

const lang = getLang(Astro.url);
const p = (path: string) => localizedPath(path, lang);
---

<BaseLayout title="Page introuvable — Jamm Immobilier" description="Cette page n'existe pas." solidNav>
  <section class="min-h-[70vh] grid place-items-center bg-background py-16">
    <div class="container max-w-2xl text-center">
      <p class="text-[11px] uppercase tracking-[0.18em] font-semibold text-secondary mb-3">Erreur 404</p>
      <h1 class="font-serif font-light text-[clamp(40px,7vw,96px)] leading-none tracking-tight">
        <span class="italic text-primary">Oups</span>, page introuvable.
      </h1>
      <p class="mt-5 text-muted-foreground max-w-prose mx-auto text-[16px] leading-relaxed">
        L'URL que vous avez suivie n'existe pas ou plus. Vérifiez son orthographe,
        ou retournez à l'accueil pour parcourir nos biens.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href={p('/')} class="inline-flex items-center gap-2 px-6 py-3.5 rounded-full bg-primary text-primary-foreground font-semibold shadow hover:translate-y-[-1px] transition">
          Retour à l'accueil
        </a>
        <a href={p('/biens')} class="inline-flex items-center gap-2 px-6 py-3.5 rounded-full bg-card border border-clay font-semibold hover:border-primary transition">
          Voir les annonces
        </a>
        <a href={p('/contact')} class="inline-flex items-center gap-2 px-6 py-3.5 rounded-full bg-secondary text-secondary-foreground font-semibold hover:translate-y-[-1px] transition">
          Nous contacter
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
