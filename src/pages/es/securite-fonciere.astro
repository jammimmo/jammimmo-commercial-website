---
/**
 * /securite-fonciere — outil lead-magnet « Sécurité foncière » (anti-arnaque).
 *
 * Miroir de /budget : page MINCE et 100 % statique côté runtime — prerender,
 * dérive `lang`, fixe title/description depuis l'i18n, et délègue tout
 * l'interactif à l'île React `SafetyTool` montée en `client:load` (l'outil EST
 * le cœur de la page).
 *
 * Aucun gate avant l'outil : l'en-tête est purement marketing, l'utilisateur
 * arrive directement sur le questionnaire (gratuit, sans contact). La capture
 * (1 champ WhatsApp) n'apparaît qu'APRÈS le résultat, dans l'île.
 *
 * Les 3 fichiers (FR, en/, wo/) sont byte-identiques : getLang() dérive la
 * langue depuis le préfixe d'URL.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolSeoSection from '@/components/seo/ToolSeoSection.astro';
import JsonLdBreadcrumb from '@/components/seo/JsonLdBreadcrumb.astro';
import SafetyTool from '@/components/safety/SafetyTool.tsx';
import Ornament from '@/components/decor/Ornament.astro';
import { getLang, t } from '@/lib/i18n';

export const prerender = true;
const lang = getLang(Astro.url);
---

<BaseLayout
  title={`${t('safety.meta.title', lang)} — ${t('site.name', lang)}`}
  description={t('safety.meta.description', lang)}
  solidNav
>
  <section class="relative py-16 sm:py-20 bg-card border-b border-clay overflow-hidden">
    {/* Fioriture: Sahel sun-glow + woven dot texture (same as favoris/hubs). */}
    <div class="absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
      <div
        class="absolute -top-24 left-1/2 -translate-x-1/2 w-[520px] h-[520px] rounded-full opacity-[0.12]"
        style="background: radial-gradient(circle at 50% 30%, hsl(var(--secondary)), hsl(var(--ochre)) 45%, transparent 70%); filter: blur(8px);"
      ></div>
      <div
        class="absolute inset-0 opacity-50"
        style="background-image: var(--sahel-weave-bg); background-size: var(--sahel-weave-size); background-position: var(--sahel-weave-pos);"
      ></div>
    </div>
    <div class="container max-w-3xl text-center relative z-10">
      <p class="text-[11px] uppercase tracking-[0.18em] font-semibold text-secondary-strong mb-3">
        {t('safety.page.eyebrow', lang)}
      </p>
      <h1 class="font-serif font-light text-[clamp(36px,5vw,56px)] leading-tight tracking-tight">
        {t('safety.page.title', lang)}
      </h1>
      <div class="flex justify-center mt-5">
        <Ornament />
      </div>
      <p class="mt-5 text-muted-foreground text-[16px] leading-relaxed">
        {t('safety.page.subtitle', lang)}
      </p>
    </div>
  </section>

  <section class="py-12 sm:py-16 bg-background">
    <div class="container max-w-2xl">
      <SafetyTool client:load lang={lang} />
    </div>
  </section>

  <JsonLdBreadcrumb slot="head" lang={lang} items={[{ name: t('breadcrumb.home', lang), path: '/' }, { name: t('nav.safety', lang), path: '/securite-fonciere' }]} />
  <ToolSeoSection lang={lang} slug="securite-fonciere" />
</BaseLayout>
