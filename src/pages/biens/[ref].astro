---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailContent from '@/components/property/DetailContent.astro';
import JsonLdProperty from '@/components/seo/JsonLdProperty.astro';
import { listAllPublicRefs, getPublicPropertyByRef, findSimilar } from '@/lib/supabase.build';
import { metaDescription, propertySeoTitle } from '@/lib/format';
import { slugToRef } from '@/lib/reference';
import { t, getLang } from '@/lib/i18n';

export const prerender = true;

export async function getStaticPaths() {
  const refs = await listAllPublicRefs();
  return refs.map((r) => ({ params: { ref: r.reference.toLowerCase() } }));
}

const { ref } = Astro.params;
if (!ref) return Astro.redirect('/biens', 307);

const property = await getPublicPropertyByRef(slugToRef(ref));
const lang = getLang(Astro.url);

if (!property) {
  // We're at build time; just render an empty 404 page. Astro will emit a
  // 404 if the param wasn't in getStaticPaths anyway. This branch covers
  // the (rare) case where the prop disappeared between path collection and
  // detail fetch.
  return Astro.redirect('/404', 307);
}

const similar = await findSimilar(property, 3);

const seoTitle = propertySeoTitle(property, lang);
// Fall back to the SEO title when a listing has neither commercial_message nor
// description (else we'd emit an empty <meta name="description">).
const seoDescription = metaDescription(property.commercial_message, property.description) || seoTitle;
const seoImage = property.images[0];
const canonical = `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://jammimmo.com'}${Astro.url.pathname}`;
// Preload the hero photo (LCP) so the browser starts fetching it in parallel
// with the gallery island's JS instead of waiting for hydration to discover it.
const lcpImage = /^https?:\/\//.test(seoImage ?? '') ? seoImage : undefined;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  canonical={canonical}
  solidNav
  hideWhatsappFab
>
  <slot slot="head">
    {lcpImage && <link rel="preload" as="image" href={lcpImage} fetchpriority="high" />}
    <JsonLdProperty property={property} url={canonical} lang={lang} />
  </slot>
  <DetailContent property={property} similar={similar} lang={lang} />
</BaseLayout>
