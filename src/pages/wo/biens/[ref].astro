---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailContent from '@/components/property/DetailContent.astro';
import JsonLdProperty from '@/components/seo/JsonLdProperty.astro';
import { listAllPublicRefs, getPublicPropertyByRef, findSimilar } from '@/lib/supabase.build';
import { formatRentalPrice, metaDescription } from '@/lib/format';
import { slugToRef } from '@/lib/reference';
import { getLang } from '@/lib/i18n';

export const prerender = true;

export async function getStaticPaths() {
  const refs = await listAllPublicRefs();
  return refs.map((r) => ({ params: { ref: r.reference.toLowerCase() } }));
}

const { ref } = Astro.params;
if (!ref) return Astro.redirect('/wo/biens', 307);

const property = await getPublicPropertyByRef(slugToRef(ref));
const lang = getLang(Astro.url);

if (!property) return Astro.redirect('/wo/biens', 307);

const similar = await findSimilar(property, 3);
const seoTitle = `${property.type} ${property.surface > 0 ? `${property.surface}m² ` : ''}${property.quartier} ${property.city} — ${formatRentalPrice(property.price, property.transaction_type)} | Jamm Immobilier`;
const seoDescription = metaDescription(property.commercial_message, property.description);
const seoImage = property.images[0];
const canonical = `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://jammimmo.com'}${Astro.url.pathname}`;
---

<BaseLayout title={seoTitle} description={seoDescription} image={seoImage} type="article" canonical={canonical} solidNav>
  <slot slot="head">
    <JsonLdProperty property={property} url={canonical} />
  </slot>
  <DetailContent property={property} similar={similar} lang={lang} />
</BaseLayout>
