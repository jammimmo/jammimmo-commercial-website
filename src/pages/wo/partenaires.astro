---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PartnerContent from '@/components/partner/PartnerContent.astro';
import { getLang, t } from '@/lib/i18n';

export const prerender = true;
const lang = getLang(Astro.url);
---

<BaseLayout
  title={`${t('partner.meta.title', lang)} — ${t('site.name', lang)}`}
  description={t('partner.meta.description', lang)}
>
  <PartnerContent lang={lang} />
</BaseLayout>
