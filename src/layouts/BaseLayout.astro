---
import '@/styles/globals.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import SeoTags from '@/components/seo/SeoTags.astro';
import JsonLdOrg from '@/components/seo/JsonLdOrg.astro';
import { getLang, t } from '@/lib/i18n';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  /** Force the nav to its solid (opaque) state from the top of the page. */
  solidNav?: boolean;
}

const lang = getLang(Astro.url);
const {
  title = `${t('site.name', lang)} — ${t('site.tagline', lang)}`,
  description = t('site.description', lang),
  image,
  type,
  canonical,
  solidNav,
} = Astro.props;

// Search-engine + analytics verification — empty strings disable each.
// Set these in CF Pages env (production + preview) once the accounts exist:
//   PUBLIC_GSC_VERIFICATION    — Google Search Console (`google-site-verification` value, NOT the file approach)
//   PUBLIC_BING_VERIFICATION   — Bing Webmaster (`msvalidate.01`)
//   PUBLIC_CF_ANALYTICS_TOKEN  — Cloudflare Web Analytics beacon token (cookieless)
//   PUBLIC_ANALYTICS_ENDPOINT  — Origin of the estate-flow Worker (custom OSS backend)
//                                e.g. https://jammimmo-estate-flow.jammimmo221admin.workers.dev
//   PUBLIC_CLARITY_PROJECT_ID  — Microsoft Clarity project ID (heatmaps + replay, parallel)
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION ?? '';
const bingVerification = import.meta.env.PUBLIC_BING_VERIFICATION ?? '';
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN ?? '';
const analyticsEndpoint = (import.meta.env.PUBLIC_ANALYTICS_ENDPOINT ?? '').replace(/\/$/, '');
const clarityProjectId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID ?? '';
const clarityEnabled = !!clarityProjectId;

// Only emit the global Organization+WebSite JSON-LD on root-shaped pages.
const isHome = ['/', '/en', '/en/', '/wo', '/wo/'].includes(Astro.url.pathname);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Self-hosted fonts via @fontsource — see src/styles/globals.css for the
        full @import list (Fraunces, Plus Jakarta Sans, JetBrains Mono).
        Loaded same-origin, with `font-display: swap` (default), so no FOIT
        and no third-party DNS hop. Bundled WOFF2s ship under /_astro/ with
        content hashes — preloads are intentionally omitted to keep the URLs
        from going stale across builds. */}
    <link rel="preconnect" href="https://pub-15cb63d8148e4d51807e901562b85914.r2.dev" />

    <SeoTags lang={lang} title={title} description={description} image={image} type={type} canonical={canonical} />

    {/* Search-engine ownership verification */}
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}

    {/* Global JSON-LD. The Organization/RealEstateAgent node is emitted on
        EVERY page so the `#organization` @id that property + geo pages
        reference (broker/seller/publisher) always resolves and the entity is
        reinforced site-wide. The WebSite + SearchAction node is homepage-only
        (the search-box sitelink is a homepage feature). */}
    <JsonLdOrg lang={lang} includeWebsite={isHome} />

    <slot name="head" />
  </head>
  <body class="min-h-screen text-foreground font-sans antialiased">
    {/* Skip-link: first focusable element so keyboard users jump past the
        nav directly to <main>. Visually hidden until focused. */}
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-full focus:bg-primary focus:text-primary-foreground focus:font-semibold focus:shadow-lg"
    >
      Aller au contenu principal
    </a>

    <Header lang={lang} solid={solidNav} />
    <main id="main" class={solidNav ? 'pt-[78px]' : ''}><slot /></main>
    <Footer lang={lang} />

    {/* Cloudflare Web Analytics — privacy-friendly, no cookies, no consent
        banner required. Token is created from CF dashboard → Web Analytics. */}
    {cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${cfAnalyticsToken}"}`}
      ></script>
    )}

    {/* Microsoft Clarity — heatmaps + session replay. Uses one first-party
        cookie (_clck/_clsk) for session continuity; disclosed on /cookies.
        Custom events fire via window.clarity('event', name). Inline `(c,l,a,r,i,t,y)`
        is Clarity's official snippet — adapted here as a templated string so
        the project ID is build-time-bound. Runs in PARALLEL with our custom
        backend below — the goal is side-by-side accuracy comparison. */}
    {clarityEnabled && (
      <script is:inline set:html={`
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "${clarityProjectId}");
      `}></script>
    )}

    {/* Custom OSS analytics — posts events to the estate-flow worker so
        leads, conversions, and custom events live in our own Supabase
        (queryable in estate-flow /analytics). Auto-fires a pageview on first
        idle frame; user-action events fire via track() in src/lib/analytics.ts.
        Skipped silently when PUBLIC_ANALYTICS_ENDPOINT is unset. */}
    {analyticsEndpoint && (
      <script is:inline define:vars={{ endpoint: analyticsEndpoint }}>{`
        (function () {
          var fire = function () {
            try {
              var sidKey = 'jamm.analytics.sid';
              var sid = sessionStorage.getItem(sidKey);
              if (!sid) {
                sid = (crypto && crypto.randomUUID) ? crypto.randomUUID() : 's_' + Math.random().toString(36).slice(2);
                sessionStorage.setItem(sidKey, sid);
              }
              var p = new URLSearchParams(location.search);
              var body = {
                type: 'pageview',
                session_id: sid,
                page_path: location.pathname,
                page_title: document.title,
                referrer: document.referrer || undefined,
                language: navigator.language,
                utm_source: p.get('utm_source') || undefined,
                utm_medium: p.get('utm_medium') || undefined,
                utm_campaign: p.get('utm_campaign') || undefined,
              };
              var json = JSON.stringify(body);
              var url = endpoint.replace(/\\/$/, '') + '/api/analytics/track';
              if (navigator.sendBeacon) {
                if (navigator.sendBeacon(url, new Blob([json], { type: 'application/json' }))) return;
              }
              fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: json, keepalive: true, mode: 'cors', credentials: 'omit' }).catch(function () {});
            } catch (_) { /* swallow */ }
          };
          if ('requestIdleCallback' in window) requestIdleCallback(fire);
          else setTimeout(fire, 0);
        })();
      `}</script>
    )}

    <script>
      // IntersectionObserver-based reveal for elements with .reveal class.
      // Skipped for visitors who prefer reduced motion.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduceMotion) {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      }
    </script>

    <script is:inline>
      // Delegated click tracker — any element with `data-track="event.name"`
      // fires the named event via the global trackers (Umami + Clarity, when
      // loaded). Optional `data-track-prop-<key>="value"` attributes become
      // event properties. Lets static Astro markup (anchors in DetailContent,
      // Footer, drawer) emit events without React boilerplate.
      document.addEventListener('click', function (e) {
        var el = e.target;
        while (el && el !== document) {
          if (el.dataset && el.dataset.track) {
            var name = el.dataset.track;
            var props = {};
            for (var k in el.dataset) {
              if (k.indexOf('trackProp') === 0 && k.length > 9) {
                // trackPropSource → source
                var propKey = k.charAt(9).toLowerCase() + k.slice(10);
                props[propKey] = el.dataset[k];
              }
            }
            try { if (window.umami) window.umami.track(name, props); } catch (_) {}
            try { if (typeof window.clarity === 'function') window.clarity('event', name); } catch (_) {}
            break;
          }
          el = el.parentNode;
        }
      }, { passive: true });
    </script>
  </body>
</html>
