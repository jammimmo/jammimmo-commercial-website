# Cloudflare Pages _headers — applied edge-side by the Pages router.
# Tier-1 security headers + CSP-report-only for visibility before we
# flip to an enforcing policy.

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.youtube-nocookie.com https://www.youtube.com https://challenges.cloudflare.com https://static.cloudflareinsights.com https://www.clarity.ms https://*.clarity.ms; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://pub-15cb63d8148e4d51807e901562b85914.r2.dev https://img.youtube.com https://i.ytimg.com https://images.unsplash.com https://picsum.photos https://fastly.picsum.photos https://*.tile.openstreetmap.org https://server.arcgisonline.com https://tile.jawg.io https://*.basemaps.cartocdn.com https://www.clarity.ms; font-src 'self'; connect-src 'self' https://api.cloudflare.com https://cloudflareinsights.com https://*.workers.dev https://*.clarity.ms; frame-src https://www.youtube-nocookie.com https://www.youtube.com https://challenges.cloudflare.com; media-src 'self' https://www.youtube-nocookie.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests

# Long-cache static assets fingerprinted by Astro
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static images / fonts shipped in /public — cache hard
/og-default.png
  Cache-Control: public, max-age=31536000, immutable

# Favicons + PWA icons + brand logo — stable /public assets, cache a month
/favicon.ico
  Cache-Control: public, max-age=2592000
/favicon-*
  Cache-Control: public, max-age=2592000
/apple-touch-icon.png
  Cache-Control: public, max-age=2592000
/android-chrome-*
  Cache-Control: public, max-age=2592000
/site.webmanifest
  Cache-Control: public, max-age=2592000
/brand/*
  Cache-Control: public, max-age=2592000

# JSON property feeds — let CDN cache for an hour, allow stale-while-revalidate
/api/property/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Webhook + intake APIs — never cache
/api/leads
  Cache-Control: no-store
  X-Robots-Tag: noindex
/api/views
  Cache-Control: no-store
  X-Robots-Tag: noindex
/api/revalidate
  Cache-Control: no-store
  X-Robots-Tag: noindex
