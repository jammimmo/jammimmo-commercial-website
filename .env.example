# Astro public env vars — exposed to the client. Anon key is meant to be public
# (RLS does the real auth work). Keep both in Cloudflare Pages env settings.
PUBLIC_SUPABASE_URL=https://ygaawqgwxlbtkcuqecxh.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server-only — Cloudflare Pages secret. Used for the /api/revalidate webhook
# signature check (HMAC). Set this to a long random string.
REVALIDATE_SECRET=

# Server-only — Cloudflare Pages Deploy Hook URL.
# Get from Pages → Settings → Builds & deployments → Deploy hooks.
DEPLOY_HOOK_URL=
