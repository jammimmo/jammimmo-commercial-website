# =============================================================================
# Tier 3 separation: admin Supabase (build-only) + Cloudflare D1 (runtime) +
# GitHub dispatch + Workers KV.
#
# BUILD-ONLY  : exposed to GitHub Actions only, never reach the runtime.
#               Read via `process.env.*` from src/lib/supabase.build.ts.
# RUNTIME     : set as Cloudflare Pages secrets (NOT env files in prod).
#               Read via `import.meta.env.*` or `locals.runtime.env.*`.
#               D1 + KV are bindings — declared in wrangler.toml, not here.
# =============================================================================

# --- BUILD-ONLY (GitHub Actions secrets) -------------------------------------
# Admin Supabase project (the SaaS DB). Service-role key — full read of
# `properties`. NEVER copy these into the Cloudflare Pages dashboard.
ADMIN_SUPABASE_URL=https://ygaawqgwxlbtkcuqecxh.supabase.co
ADMIN_SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- RUNTIME (Cloudflare Pages secrets) --------------------------------------
# HMAC secret shared with the admin Supabase pg_net trigger that calls
# /api/revalidate. Long random string (>=32 bytes).
REVALIDATE_HMAC_SECRET=

# Fine-grained GitHub PAT (Contents:write + Metadata:read on this repo) used
# to fire `repository_dispatch` events from /api/revalidate.
GH_DISPATCH_TOKEN=

# Full repo slug for the dispatch endpoint.
GH_REPO=jammimmo/jammimmo-commercial-website

# Note: INTAKE_DB (D1) and REFRESH_KV (KV) are Worker bindings, not env vars.
# They live in wrangler.toml. For local dev, wrangler creates a local SQLite
# file under .wrangler/state/ when you run `wrangler d1 execute --local`.
